                      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 12, marginBottom: 18 }}>
                        <StatBox label="寃?덉닔?? value={selectedRecord.inspectionQty} tone="blue" />
                        <StatBox label="?뚯넚?섎웾" value={selectedRecord.returnQty} tone="neutral" />
                        <StatBox label="援먰솚?섎웾" value={selectedRecord.exchangeQty} tone="red" />
                      </div>
                      <div style={{ fontSize: 16, fontWeight: 800, marginBottom: 12 }}>?ъ쭊 愿由?/div>
                      <div style={{ display: "grid", gap: 10 }}>
                        <div style={{ border: `1px solid ${colors.border}`, borderRadius: 14, padding: 12 }}>?곹뭹肄붾뱶 {selectedRecord.code || "-"}</div>
                        <div style={{ border: `1px solid ${colors.border}`, borderRadius: 14, padding: 12 }}>理쒓렐 ?섏젙 {selectedRecord.latestTime || "-"}</div>
                        <div style={{ border: `1px solid ${colors.border}`, borderRadius: 14, padding: 12 }}>寃???댁뿭 {recordCards.length}嫄?/div>
                      </div>
                    </div>
                  ) : (
                    <div>?좏깮???댁뿭???놁뒿?덈떎.</div>
                  )}
                </div>
              </div>
            ) : null}
          </div>
        ) : null}

        {activeTab === "analytics" ? (
          <div style={{ display: "grid", gap: 14 }}>
            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 16 }}>
              <div style={{ display: "grid", gap: 16 }}>
                <div style={{ border: `1px solid ${colors.border}`, borderRadius: 18, background: "#fff", padding: 16, boxShadow: colors.shadow, display: "flex", flexDirection: "column" }}>
                  <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12 }}>
                    {analyticsKpis.map((item) => (
                      <KpiCard
                        key={item.label}
                        title={item.label}
                        value={item.value}
                        sub={item.subLabel || ""}
                        tone={
                          item.label.includes("遺덈웾")
                            ? "red"
                            : item.label.includes("寃??)
                            ? "green"
                            : item.label.includes("SKU")
                            ? "purple"
                            : item.label.includes("??) || item.label.includes("瑜?)
                            ? "orange"
                            : "blue"
                        }
                      />
                    ))}
                  </div>
                </div>
                <div style={{ border: `1px solid ${colors.border}`, borderRadius: 18, background: "#fff", padding: 16, boxShadow: colors.shadow }}>
                  <button type="button" onClick={onSummaryAction} style={{ width: "100%", height: 50, borderRadius: 12, border: "none", background: colors.green, color: "#fff", fontSize: 16, fontWeight: 800, marginBottom: 12 }}>?붿빟 怨꾩궛</button>
                  <button type="button" onClick={onHappycallUploadClick} style={{ width: "100%", height: 50, borderRadius: 12, border: `1px solid ${colors.orange}`, background: "#fff", color: colors.orange, fontSize: 16, fontWeight: 800, marginBottom: 12 }}>?댄뵾肄??낅줈??/button>
                  <button type="button" onClick={onFlushPending} style={{ width: "100%", height: 50, borderRadius: 12, border: `1px solid ${colors.blue}`, background: "#fff", color: colors.blue, fontSize: 16, fontWeight: 800 }}>????쇨큵)</button>
                </div>
              </div>
              <div style={{ display: "grid", gap: 16 }}>
                <div style={{ border: `1px solid ${colors.border}`, borderRadius: 18, background: "#fff", padding: 16, boxShadow: colors.shadow }}>
                  <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 16 }}>
                    <span style={{ fontSize: 16, fontWeight: 800 }}>ZIP ?ㅼ슫濡쒕뱶</span>
                    <span style={{ fontSize: 14, color: colors.muted }}>(20MB 遺꾪븷)</span>
                  </div>
                  <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10, marginBottom: 16 }}>
                    <button type="button" onClick={onDownloadInspectionZip} style={zipButtonStyle}>{zipDownloading === "inspection" ? "ZIP ?앹꽦 以?.." : "寃?덉궗吏????}</button>
                    <button type="button" onClick={onDownloadMovementZip} style={zipButtonStyle}>遺덈웾?ъ쭊 ???/button>
                    <button type="button" onClick={onDownloadMovementZip} style={zipButtonStyle}>?밸룄?ъ쭊 ???/button>
                    <button type="button" onClick={onDownloadMovementZip} style={zipButtonStyle}>以묐웾?ъ쭊 ???/button>
                  </div>
                  <div style={{ border: `1px dashed ${colors.border}`, borderRadius: 16, minHeight: 410, display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", textAlign: "center", padding: 24, background: "#fbfdff", marginTop: 8 }}>
                    <div style={{ fontSize: 15, fontWeight: 800, marginBottom: 8 }}>?앹꽦??ZIP ?뚯씪???놁뒿?덈떎.</div>
                    <div style={{ fontSize: 13, color: colors.muted, lineHeight: 1.7, maxWidth: 360 }}>
                      寃?덉궗吏? 遺덈웾?ъ쭊, 以묐웾?ъ쭊, ?밸룄?ъ쭊???꾩쟻?섎㈃ ?ㅼ슫濡쒕뱶 ?쒖젏??ZIP???앹꽦?⑸땲??
                      <br />
                      20MB瑜?珥덇낵?섎㈃ ?먮룞?쇰줈 遺꾪븷 ZIP??異붽? ?앹꽦?⑸땲??
                    </div>
                  </div>
                </div>
                <div style={{ border: `1px solid ${colors.border}`, borderRadius: 18, background: "#fff", padding: 16, boxShadow: colors.shadow }}>
                  <div style={{ display: "flex", gap: 8, marginBottom: 12 }}>
                    {[["1d", "?쇰퀎"], ["7d", "二쇰퀎"], ["30d", "?붾퀎"]].map(([key, label]) => (
                      <button key={key} type="button" onClick={() => onSelectPeriod(key)} style={{ height: 34, padding: "0 13px", borderRadius: 10, border: selectedHappycallPeriod === key ? "1px solid #a9ccff" : `1px solid ${colors.border}`, background: selectedHappycallPeriod === key ? colors.blueSoft : "#fff", color: selectedHappycallPeriod === key ? colors.blue : colors.muted, fontSize: 13, fontWeight: 700 }}>{label}</button>
                    ))}
                  </div>
                  <div style={{ display: "grid", gap: 10 }}>
                    {[happycallHeroCard, ...happycallMiniCards].filter(Boolean).map((entry) => {
                      const medalColor = entry.rank === 1 ? "#c9971a" : entry.rank === 2 ? "#73839b" : entry.rank === 3 ? "#ad6b3b" : colors.text;
                      const medalBg = entry.rank === 1 ? "#fff4cf" : entry.rank === 2 ? "#eef3f8" : entry.rank === 3 ? "#f8eadf" : "#fbfdff";
                      return (
                        <div key={`top-${entry.rank}-${entry.productCode || entry.productName}`} style={{ border: `1px solid ${colors.border}`, borderRadius: 14, background: "#fbfdff", padding: "12px 14px", fontSize: 14, fontWeight: 700, display: "flex", alignItems: "center", gap: 10 }}>
                          <span style={{ minWidth: 62, height: 30, padding: "0 10px", borderRadius: 999, background: medalBg, color: medalColor, display: "inline-flex", alignItems: "center", justifyContent: "center", fontWeight: 800 }}>{`TOP.${entry.rank}`}</span>
                          <span style={{ flex: 1 }}>{entry.productName}{entry.partnerName ? `(${entry.partnerName})` : ""}</span>
                          <span style={{ fontWeight: 800 }}>{formatCount(entry.count)}</span>
                        </div>
                      );
                    })}
                  </div>
                </div>
              </div>
            </div>
          </div>
        ) : null}
      </div>
    </div>
  );
}


