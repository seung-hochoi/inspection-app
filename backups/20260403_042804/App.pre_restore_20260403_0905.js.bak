            <span style={{ height: 24, padding: "0 10px", borderRadius: 999, background: "#eaf2ff", color: "#2563eb", display: "inline-flex", alignItems: "center", fontSize: 12, fontWeight: 700 }}>
              {recordDetailDraft.partnerName || "-"}
            </span>
          </div>

          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 12 }}>
            <StatCard title="寃?덉닔?? value={recordDetailDraft.inspectionQty || "0"} tone="blue" />
            <StatCard title="?뚯넚?섎웾" value={recordDetailDraft.returnQty || "0"} tone="neutral" />
            <StatCard title="援먰솚?섎웾" value={recordDetailDraft.exchangeQty || "0"} tone="red" />
