const createEditorProfile = () => {
  try {
    const storageKey = "inspection_editor_profile_v1";
    const raw = window.localStorage.getItem(storageKey);
    if (raw) {
      const parsed = JSON.parse(raw);
      if (parsed?.editorId && parsed?.editorName) {
        return parsed;
      }
    }

    const editorId = `device_${Math.random().toString(36).slice(2, 10)}`;
    const editorName = `?꾩옣?-${editorId.slice(-4)}`;
    const next = { editorId, editorName };
    window.localStorage.setItem(storageKey, JSON.stringify(next));
    return next;
  } catch (_) {
    const editorId = `device_${Math.random().toString(36).slice(2, 10)}`;
    return { editorId, editorName: `?꾩옣?-${editorId.slice(-4)}` };
  }
};

const formatDateTime = (value) => {
  if (!value) return "-";
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return String(value);
  return date.toLocaleString("ko-KR");
};

const makeHistoryProductKey = (partnerName, productCode) =>
  `${String(partnerName || "").trim()}||${normalizeProductCode(productCode || "")}`;

const parseBrixInput = (value) => {
  const text = String(value ?? "").trim();
  if (!text) return NaN;
  const numeric = Number(text);
  return Number.isFinite(numeric) ? numeric : NaN;
};

const formatBrixValue = (value) => {
  const numeric = Number(value);
  if (!Number.isFinite(numeric)) return "";
  return numeric % 1 === 0 ? numeric.toFixed(1) : numeric.toFixed(2).replace(/0$/, "");
};

const computeBrixAvg = (min, max) => {
  if (!Number.isFinite(min) || !Number.isFinite(max)) return "";
  return formatBrixValue((min + max) / 2);
};

const PHOTO_TYPE_OPTIONS = [
  { key: "inspection", label: "검품사진", scope: "inspection" },
  { key: "return", label: "회송사진", scope: "movement" },
  { key: "exchange", label: "교환사진", scope: "movement" },
  { key: "sugar", label: "당도사진", scope: "inspection" },
  { key: "weight", label: "중량사진", scope: "inspection" },
];

const PHOTO_TYPE_LABEL_MAP = PHOTO_TYPE_OPTIONS.reduce((acc, item) => {
  acc[item.key] = item.label;
  return acc;
}, {});

const toPhotoItemsFromUrls = (sources, photoType) =>
  (Array.isArray(sources) ? sources : [])
    .map((source, index) => {
      const driveUrl = String(source?.driveUrl || source?.previewUrl || source?.url || "").trim();
      const fileId = String(source?.fileId || extractGoogleDriveId(driveUrl) || "").trim();
      const previewUrl =
        String(source?.previewUrl || "").trim() ||
        (fileId ? `https://drive.google.com/thumbnail?id=${fileId}&sz=w1200` : driveUrl);
      const fileName = String(source?.fileName || source?.name || `${photoType}-${index + 1}`).trim();
      if (!previewUrl && !driveUrl && !fileId) return null;
      return {
        id: `${photoType}-${fileId || index}`,
        fileId,
        driveUrl: driveUrl || previewUrl,
        previewUrl,
        fileName,
        photoType,
        persisted: true,
      };
    })
    .filter(Boolean);

const formatDashboardValue = (label, value) => {
  if (value == null || value === "") return "-";
  if (
    String(label).includes("율") ||
    String(label).includes("률") ||
    String(label).includes("커버리지")
  ) {
    const numeric = Number(value);
    return Number.isFinite(numeric) ? `${(numeric * 100).toFixed(1)}%` : String(value);
  }
  if (typeof value === "number") {
    return value.toLocaleString("ko-KR");
  }
  const numeric = Number(value);
  if (Number.isFinite(numeric) && String(value).trim() !== "") {
    return numeric.toLocaleString("ko-KR");
  }
  return String(value);
};

void formatDashboardValue;

const getRecordType = (record) => {
  const type = String(
    record["처리유형"] ||
      record["movementType"] ||
      record.type ||
      ""
  ).trim();
  if (type) return type;
  if (parseQty(record["회송수량"] || record.returnQty) > 0) return "회송";
  if (parseQty(record["교환수량"] || record.exchangeQty) > 0) return "교환";
  return "기타";
};

const getRecordQtyText = (record) => {
  const type = getRecordType(record);
  if (type === "회송" || type === "RETURN") return `${parseQty(record["회송수량"] || record.returnQty)}개`;
  if (type === "교환" || type === "EXCHANGE") return `${parseQty(record["교환수량"] || record.exchangeQty)}개`;

  const returnQty = parseQty(record["회송수량"] || record.returnQty);
  const exchangeQty = parseQty(record["교환수량"] || record.exchangeQty);
  if (returnQty > 0 && exchangeQty > 0) {
    return `회송 ${returnQty}개 / 교환 ${exchangeQty}개`;
  }
  return `${Math.max(returnQty, exchangeQty, 0)}개`;
};

const formatDateForFileName = () => new Date().toLocaleDateString("sv-SE");

const base64ToBlob = (base64, mimeType = "application/octet-stream") => {
  const binary = window.atob(String(base64 || ""));
  const chunkSize = 1024;
  const bytes = [];

  for (let offset = 0; offset < binary.length; offset += chunkSize) {
    const slice = binary.slice(offset, offset + chunkSize);
    const array = new Uint8Array(slice.length);

    for (let i = 0; i < slice.length; i += 1) {
      array[i] = slice.charCodeAt(i);
    }

    bytes.push(array);
  }

  return new Blob(bytes, { type: mimeType });
};

const extractImageFormulaUrl = (value) => {
  const text = String(value || "").trim();
  const match = text.match(/^=IMAGE\("(.+)"\)$/i);
  return match ? match[1] : text;
};

const extractGoogleDriveId = (value) => {
  const text = String(value || "").trim();
  if (!text) return "";

  const directId = text.match(/^[a-zA-Z0-9_-]{20,}$/);
  if (directId) return directId[0];

  const fileMatch = text.match(/\/file\/d\/([a-zA-Z0-9_-]+)/);
  if (fileMatch) return fileMatch[1];

  const openMatch = text.match(/[?&]id=([a-zA-Z0-9_-]+)/);
  if (openMatch) return openMatch[1];

  const ucMatch = text.match(/\/d\/([a-zA-Z0-9_-]+)/);
  if (ucMatch) return ucMatch[1];

  return "";
};

const buildPhotoCandidate = (rawValue) => {
  const normalized = extractImageFormulaUrl(rawValue);
  const text = String(normalized || "").trim();
  if (!text) return null;

  const driveId = extractGoogleDriveId(text);
  if (driveId) {
    return {
      key: driveId,
      previewUrl: `https://drive.google.com/thumbnail?id=${driveId}&sz=w1200`,
      downloadUrl: `https://drive.google.com/uc?export=download&id=${driveId}`,
    };
  }

  if (/^https?:\/\//i.test(text)) {
    return {
      key: text,
      previewUrl: text,
      downloadUrl: text,
    };
  }

  return null;
};

const splitPhotoSourceText = (value) =>
  String(value || "")
    .split(/\r?\n|[,;]+/)
    .map((item) => item.trim())
    .filter(Boolean);

const getPhotoCandidatesFromRecord = (record) => {
  const rawItems = [
    record?.["사진URL"] || record?.photoUrl,
    record?.["사진링크"] || record?.photoLink,
    ...splitPhotoSourceText(record?.["사진링크목록"] || record?.photoLinks),
    ...splitPhotoSourceText(record?.["사진파일ID목록"] || record?.photoFileIds),
  ];

  const seen = {};
  const candidates = [];

  rawItems.forEach((item) => {
    const candidate = buildPhotoCandidate(item);
    if (!candidate || seen[candidate.key]) return;
    seen[candidate.key] = true;
    candidates.push(candidate);
  });

  return candidates;
};

function HistoryPhotoItem({ candidate, index, onOpen, styles }) {
  const [failed, setFailed] = useState(false);

  if (failed) {
    return <div style={styles.photoThumbEmpty}>미리보기 불가</div>;
  }

  return (
    <img
      src={candidate.previewUrl}
      alt={`첨부 사진 ${index + 1}`}
      style={styles.photoThumb}
      onClick={() => onOpen(candidate.previewUrl)}
      onError={() => setFailed(true)}
    />
  );
}

function HistoryPhotoPreview({ record, onOpen, styles }) {
  const candidates = useMemo(() => getPhotoCandidatesFromRecord(record), [record]);

  if (!candidates.length) {
    return <div style={styles.photoEmpty}>사진 없음</div>;
  }

  return (
    <div style={styles.photoGrid}>
      {candidates.map((candidate, index) => (
        <HistoryPhotoItem
          key={candidate.key || `${record.__rowNumber || "row"}-${index}`}
          candidate={candidate}
          index={index}
          onOpen={onOpen}
          styles={styles}
        />
      ))}
    </div>
  );
}

function DraftPhotoPreviewItem({ file, index, onRemove, onRetry, styles }) {
  const [previewUrl, setPreviewUrl] = useState("");

  useEffect(() => {
    if (!file) {
      setPreviewUrl("");
      return undefined;
    }

    if (isUploadedPhotoItem(file)) {
      setPreviewUrl(file.previewUrl || file.viewUrl || "");
      return undefined;
    }

    if (isLocalPhotoItem(file) && file.previewUrl) {
      setPreviewUrl(file.previewUrl);
      return undefined;
    }

    const sourceFile = isLocalPhotoItem(file) ? file.file : file;
    if (!sourceFile) {
      setPreviewUrl("");
      return undefined;
    }

    const nextUrl = URL.createObjectURL(sourceFile);
    setPreviewUrl(nextUrl);

    return () => {
      URL.revokeObjectURL(nextUrl);
    };
  }, [file]);

  return (
    <div style={styles.draftPhotoCard}>
      {previewUrl ? (
        <img src={previewUrl} alt={file?.fileName || file?.name || `?좏깮 ?ъ쭊 ${index + 1}`} style={styles.draftPhotoImage} />
      ) : (
        <div style={styles.photoThumbEmpty}>誘몃━蹂닿린 遺덇?</div>
      )}
      {isLocalPhotoItem(file) ? (
        <div
          style={{
            position: "absolute",
            left: 8,
            bottom: 8,
            padding: "2px 6px",
            borderRadius: 999,
            fontSize: 10,
            fontWeight: 700,
            background: file.status === "failed" ? "#fee2e2" : file.status === "uploading" ? "#dbeafe" : "#ecfdf3",
            color: file.status === "failed" ? "#b91c1c" : file.status === "uploading" ? "#1d4ed8" : "#166534",
          }}
        >
          {file.status === "failed" ? "?ㅽ뙣" : file.status === "uploading" ? "?낅줈?쒖쨷" : "?湲?}
        </div>
      ) : null}
      <button
        type="button"
        onClick={() => onRemove(index)}
        style={styles.draftPhotoRemoveButton}
        aria-label={`?좏깮 ?ъ쭊 ${index + 1} ??젣`}
      >
        ??
      </button>
      {isLocalPhotoItem(file) && file.status === "failed" && typeof onRetry === "function" ? (
        <button
          type="button"
          onClick={() => onRetry(index)}
          style={{
            position: "absolute",
            right: 8,
            bottom: 8,
            border: "none",
            borderRadius: 8,
            padding: "4px 8px",
            background: "#111827",
            color: "#fff",
            fontSize: 11,
            fontWeight: 700,
            cursor: "pointer",
          }}
        >
          ?ъ떆??
        </button>
      ) : null}
    </div>
  );
}

function DraftPhotoPreviewList({ files, onRemove, onRetry, styles }) {
  if (!Array.isArray(files) || files.length === 0) {
    return <div style={styles.draftPhotoEmpty}>?좏깮???ъ쭊 ?놁쓬</div>;
  }

  return (
    <div style={styles.draftPhotoGrid}>
      {files.map((file, index) => (
        <DraftPhotoPreviewItem
          key={`${file?.name || "photo"}-${file?.lastModified || index}-${index}`}
          file={file}
          index={index}
          onRemove={onRemove}
          onRetry={onRetry}
          styles={styles}
        />
      ))}
    </div>
  );
}

function ProductImage({ product, src, alt, style }) {
  const [currentSrc, setCurrentSrc] = useState(src || getDefaultProductImageSrc(product) || DEFAULT_PRODUCT_IMAGE_SRC);

  useEffect(() => {
    setCurrentSrc(src || getDefaultProductImageSrc(product) || DEFAULT_PRODUCT_IMAGE_SRC);
  }, [product, src]);

  return (
    <img
      src={currentSrc}
      alt={alt}
      style={style}
      onError={() => {
        const fallbackSrc = getDefaultProductImageSrc(product);
        if (fallbackSrc && fallbackSrc !== currentSrc) {
          setCurrentSrc(fallbackSrc);
          return;
        }
        if (currentSrc !== DEFAULT_PRODUCT_IMAGE_SRC) {
          setCurrentSrc(DEFAULT_PRODUCT_IMAGE_SRC);
          return;
        }
        if (currentSrc !== SECONDARY_PRODUCT_IMAGE_SRC) {
          setCurrentSrc(SECONDARY_PRODUCT_IMAGE_SRC);
        }
      }}
    />
  );
}

const detailInputStyle = {
  width: "100%",
  minHeight: 42,
  borderRadius: 12,
  border: "1px solid #d8e2ef",
  padding: "0 12px",
  boxSizing: "border-box",
  fontSize: 15,
  color: "#15253e",
  outline: "none",
  background: "#fff",
};

function InputRow({ label, children }) {
  return (
    <div style={{ display: "grid", gap: 6 }}>
      <div style={{ fontSize: 13, color: "#516274", fontWeight: 700 }}>{label}</div>
      {children}
    </div>
  );
}

function StatCard({ title, value, tone = "neutral" }) {
  const toneMap = {
    blue: { border: "#9ec5ff", background: "#f5f9ff", color: "#2563eb" },
    red: { border: "#ffc9c9", background: "#fff7f7", color: "#ef4444" },
    neutral: { border: "#d8e2ef", background: "#fff", color: "#15253e" },
  };
  const colors = toneMap[tone] || toneMap.neutral;

  return (
    <div style={{ border: `1px solid ${colors.border}`, borderRadius: 16, background: colors.background, padding: "14px 12px", textAlign: "center" }}>
      <div style={{ fontSize: 13, color: "#516274", fontWeight: 700, marginBottom: 8 }}>{title}</div>
      <div style={{ fontSize: 18, fontWeight: 900, color: colors.color }}>{value}</div>
    </div>
  );
}

