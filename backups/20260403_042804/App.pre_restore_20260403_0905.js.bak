              </InputRow>
              <InputRow label="理쒓퀬媛?>
                <input value={recordDetailDraft.brixMax} onChange={(event) => updateRecordDetailDraft({ brixMax: event.target.value.replace(/[^\d.]/g, "") })} style={detailInputStyle} />
              </InputRow>
              <InputRow label="?됯퇏">
                <div style={{ ...detailInputStyle, display: "flex", alignItems: "center", background: "#f8fbff" }}>{recordDetailDraft.brixAvg || "-"}</div>
