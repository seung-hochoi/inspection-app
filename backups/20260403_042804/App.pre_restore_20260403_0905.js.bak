                defect: filteredHistoryRows.filter((row) => makeHistoryProductKey(row["?묐젰?щ챸"] || row.partnerName || row["?臾먯젾??梨?] || "", row["?곹뭹肄붾뱶"] || row.productCode || row["?怨밸??꾨뗀諭?] || "") === item.key).reduce((sum, row) => sum + parseQty(row["?ъ쭊媛쒖닔"] || 0), 0),
              };
              return (
