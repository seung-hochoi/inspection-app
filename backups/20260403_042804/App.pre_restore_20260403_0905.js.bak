  const saveQueueItems = useMemo(() => {
    return Object.values(pendingMap || {})
      .map((entry) => {
        const statusKey = entry.draftKey || entry.key;
        const status = itemStatusMap[statusKey] || itemStatusMap[entry.key] || "pending";
        return {
          key: entry.key,
          title: buildQueueItemTitle(entry),
          status,
          progress: getStatusProgress(status),
        };
      })
      .filter((item) => item.title)
      .sort((a, b) => a.title.localeCompare(b.title, "ko"));
  }, [buildQueueItemTitle, itemStatusMap, pendingMap]);

  const buildInspectionPendingEntry = useCallback((product, nextDraft = {}) => {
    const entityKey = makeEntityKey(currentJob?.job_key, product.productCode, product.partner);
    const draftKey = `inspection||${product.partner}||${product.productCode}`;
    const photoItems = serializePhotoItems(nextDraft.photoFiles);
    const serverState = inspectionSavedMap[entityKey] || {};

    return {
      key: entityKey,
      draftKey,
      uploadQueueKey: entityKey,
      type: "inspection",
      ?묒뾽湲곗??쇰삉?봀SV?앸퀎媛? currentJob?.job_key || "",
      ?묒꽦?쇱떆: new Date().toISOString(),
      ?곹뭹肄붾뱶: product.productCode,
      ?곹뭹紐? product.productName,
      ?묐젰?щ챸: product.partner,
      ?꾩껜諛쒖＜?섎웾: product.totalQty || 0,
      諛쒖＜?섎웾: product.totalQty || 0,
      寃?덉닔?? parseQty(nextDraft.inspectionQty),
      ?뚯넚?섎웾: pendingMap[entityKey]?.?뚯넚?섎웾 || 0,
      援먰솚?섎웾: pendingMap[entityKey]?.援먰솚?섎웾 || 0,
      ?쇳꽣紐? pendingMap[entityKey]?.?쇳꽣紐?|| "",
      鍮꾧퀬: pendingMap[entityKey]?.鍮꾧퀬 || "",
      ?됱궗?щ?: product.eventInfo?.?됱궗?щ? || "",
      ?됱궗紐? product.eventInfo?.?됱궗紐?|| "",
      photoItems,
      ?ъ쭊?뚯씪ID紐⑸줉: photoItems.map((item) => item.fileId).join("\n"),
      photoNames: photoItems.map((item) => item.fileName || item.name),
      expectedUpdatedAt: serverState.updatedAt || "",
      expectedVersion: Number(serverState.version || 0),
      ?섏젙?? editorProfile.editorName,
      ?섏젙?륤D: editorProfile.editorId,
    };
  }, [currentJob?.job_key, editorProfile.editorId, editorProfile.editorName, inspectionSavedMap, pendingMap, serializePhotoItems]);

  const buildMovementEntries = useCallback((product, centerName, nextDraft = {}) => {
    const centerInfo = product.centers.find((item) => item.center === centerName);
    if (!centerInfo || !currentJob?.job_key) {
      return [];
    }

    const returnQty = parseQty(nextDraft.returnQty);
    const exchangeQty = parseQty(nextDraft.exchangeQty);
    const memo = String(nextDraft.memo || "").trim();
    const photoItems = serializePhotoItems(nextDraft.photoFiles);
    const entries = [];

    if (returnQty > 0) {
      const returnKey = makeMovementPendingKey("RETURN", currentJob.job_key, product.productCode, product.partner, centerName);
      const returnServerState = movementSavedMap[returnKey] || {};
      entries.push({
        key: returnKey,
        draftKey: `return||${product.partner}||${product.productCode}||${centerName}`,
        uploadQueueKey: `return||${product.partner}||${product.productCode}||${centerName}`,
        type: "movement",
        movementType: "RETURN",
        ?묒뾽湲곗??쇰삉?봀SV?앸퀎媛? currentJob.job_key,
        ?묒꽦?쇱떆: new Date().toISOString(),
        ?곹뭹紐? product.productName,
        ?곹뭹肄붾뱶: product.productCode,
        ?쇳꽣紐? centerName,
        ?묐젰?щ챸: product.partner,
        諛쒖＜?섎웾: centerInfo.totalQty || 0,
        ?됱궗?щ?: product.eventInfo?.?됱궗?щ? || "",
        ?됱궗紐? product.eventInfo?.?됱궗紐?|| "",
        泥섎━?좏삎: "?뚯넚",
        ?뚯넚?섎웾: returnQty,
        援먰솚?섎웾: 0,
        qty: returnQty,
        鍮꾧퀬: memo,
        photoItems,
        ?ъ쭊?뚯씪ID紐⑸줉: photoItems.map((item) => item.fileId).join("\n"),
        photoNames: photoItems.map((item) => item.fileName || item.name),
        ?꾩껜諛쒖＜?섎웾: product.totalQty || 0,
        expectedUpdatedAt: returnServerState.updatedAt || "",
        expectedVersion: Number(returnServerState.version || 0),
        ?섏젙?? editorProfile.editorName,
        ?섏젙?륤D: editorProfile.editorId,
      });
    }

    if (exchangeQty > 0) {
      const exchangeKey = makeMovementPendingKey("EXCHANGE", currentJob.job_key, product.productCode, product.partner, centerName);
      const exchangeServerState = movementSavedMap[exchangeKey] || {};
      entries.push({
        key: exchangeKey,
        draftKey: `return||${product.partner}||${product.productCode}||${centerName}`,
        uploadQueueKey: `return||${product.partner}||${product.productCode}||${centerName}`,
        type: "movement",
        movementType: "EXCHANGE",
        ?묒뾽湲곗??쇰삉?봀SV?앸퀎媛? currentJob.job_key,
        ?묒꽦?쇱떆: new Date().toISOString(),
        ?곹뭹紐? product.productName,
        ?곹뭹肄붾뱶: product.productCode,
        ?쇳꽣紐? centerName,
        ?묐젰?щ챸: product.partner,
        諛쒖＜?섎웾: centerInfo.totalQty || 0,
        ?됱궗?щ?: product.eventInfo?.?됱궗?щ? || "",
        ?됱궗紐? product.eventInfo?.?됱궗紐?|| "",
        泥섎━?좏삎: "援먰솚",
        ?뚯넚?섎웾: 0,
        援먰솚?섎웾: exchangeQty,
        qty: exchangeQty,
        鍮꾧퀬: memo,
        photoItems,
        ?ъ쭊?뚯씪ID紐⑸줉: photoItems.map((item) => item.fileId).join("\n"),
        photoNames: photoItems.map((item) => item.fileName || item.name),
        ?꾩껜諛쒖＜?섎웾: product.totalQty || 0,
        expectedUpdatedAt: exchangeServerState.updatedAt || "",
        expectedVersion: Number(exchangeServerState.version || 0),
        ?섏젙?? editorProfile.editorName,
        ?섏젙?륤D: editorProfile.editorId,
      });
    }

    return entries;
  }, [currentJob?.job_key, editorProfile.editorId, editorProfile.editorName, movementSavedMap, serializePhotoItems]);

  const createMutationTask = useCallback((type, itemKey, payload, extra = {}) => {
    const operationId = extra.operationId || createOperationId(type);
    return {
      taskId: extra.taskId || createTaskId(type),
      operationId,
      type,
      itemKey,
      payload: {
        ...(payload || {}),
        operationId,
      },
      status: "pending",
      retryCount: 0,
      createdAt: Date.now(),
      lastTriedAt: 0,
      ...extra,
    };
  }, []);

  const buildPhotoMetaTaskPayload = useCallback(({ itemKey, draftKey, product, centerName = "", photoKind, action, uploadedPhoto }) => {
    const basePayload =
      centerName
        ? (buildMovementEntries(product, centerName, draftsRef.current[draftKey] || {})[0] || {})
        : buildInspectionPendingEntry(product, draftsRef.current[draftKey] || {});

    return {
      ...basePayload,
      key: itemKey,
      draftKey,
      photoAction: action,
      photoKind,
      photoItem: uploadedPhoto || null,
      photoFileId: uploadedPhoto?.fileId || "",
      photoItems: undefined,
      ?ъ쭊?뚯씪ID紐⑸줉: undefined,
    };
  }, [buildInspectionPendingEntry, buildMovementEntries]);

  const removeDraftPhoto = useCallback(async (draftKey, index, itemKey, product = null, centerName = "", photoKind = "inspection") => {
    const currentDraft = draftsRef.current[draftKey] || {};
    const currentFiles = Array.isArray(currentDraft.photoFiles) ? currentDraft.photoFiles : [];
    const currentNames = Array.isArray(currentDraft.photoNames) ? currentDraft.photoNames : [];
    const target = currentFiles[index];
    const nextPhotoFiles = currentFiles.filter((_, fileIndex) => fileIndex !== index);
    const nextPhotoNames = currentNames.filter((_, fileIndex) => fileIndex !== index);

    setDrafts((prev) => ({
      ...prev,
      [draftKey]: {
        ...currentDraft,
        photoFiles: nextPhotoFiles,
        photoNames: nextPhotoNames,
      },
    }));

    if (isUploadedPhotoItem(target) && product) {
      await enqueueTasks([
        createMutationTask("photo_meta_save", itemKey, buildPhotoMetaTaskPayload({
          itemKey,
          draftKey,
          product,
          centerName,
          photoKind,
          action: "delete",
          uploadedPhoto: target,
        })),
      ]);
    } else if (isLocalPhotoItem(target) && target.taskId) {
      await removeTask(target.taskId);
      await refreshPendingFromQueue();
    }
  }, [buildPhotoMetaTaskPayload, createMutationTask, enqueueTasks, refreshPendingFromQueue]);

  const uploadDraftPhotos = useCallback(async ({ draftKey, itemKey, baseName, files, partnerName = "", photoKind = "inspection", retryLocalIds = [], product = null, centerName = "" }) => {
    const list = Array.isArray(files) ? files : [];
    if (!list.length) return;

    const encodedPhotos = await filesToBase64(list);
    const newLocalItems = encodedPhotos.map((encoded, index) => {
      const localId = retryLocalIds[index] || `${draftKey}::${Date.now()}::${index}`;
      const task = createMutationTask("photo_upload", itemKey, {
        draftKey,
        itemKey,
        productName: baseName,
        partnerName,
        photoKind,
        localId,
        photo: encoded,
      });

      return {
        localItem: createLocalPhotoItem(null, {
          localId,
          photoKind,
          status: "pending",
          imageBase64: encoded.imageBase64,
          mimeType: encoded.mimeType,
          fileName: encoded.fileName,
          previewUrl: `data:${encoded.mimeType || "image/jpeg"};base64,${encoded.imageBase64}`,
          taskId: task.taskId,
          operationId: task.operationId,
        }),
        task,
      };
    });

    setDrafts((prev) => {
      const currentDraft = prev[draftKey] || {};
      const currentPhotos = Array.isArray(currentDraft.photoFiles) ? currentDraft.photoFiles : [];
      const targetIds = retryLocalIds.filter(Boolean);
      const cleanedPhotos = targetIds.length
        ? currentPhotos.filter((item) => !targetIds.includes(item?.localId))
        : currentPhotos;
      const nextPhotos = [...cleanedPhotos, ...newLocalItems.map((entry) => entry.localItem)];
      return {
        ...prev,
        [draftKey]: {
          ...currentDraft,
          photoFiles: nextPhotos,
          photoNames: nextPhotos.map((photo) => photo.fileName || photo.name),
          __photoContext: {
            itemKey,
            draftKey,
            productName: baseName,
            partnerName,
            photoKind,
            centerName,
            productCode: product?.productCode || "",
          },
        },
      };
    });

    await enqueueTasks(newLocalItems.map((entry) => entry.task));
    setItemStatuses([itemKey], "uploading");
  }, [createMutationTask, enqueueTasks]);

  const retryDraftPhotoUpload = useCallback(async (draftKey, index, itemKey, baseName, partnerName = "", photoKind = "inspection", product = null, centerName = "") => {
    const currentDraft = draftsRef.current[draftKey] || {};
    const target = Array.isArray(currentDraft.photoFiles) ? currentDraft.photoFiles[index] : null;
    if (!isLocalPhotoItem(target) || !target.imageBase64) return;

    const task = createMutationTask("photo_upload", itemKey, {
      draftKey,
      itemKey,
      productName: baseName,
      partnerName,
      photoKind: target.photoKind || photoKind,
      localId: target.localId,
      photo: {
        fileName: target.fileName || target.name || "photo.jpg",
        mimeType: target.mimeType || "image/jpeg",
        imageBase64: target.imageBase64,
      },
    }, {
      taskId: target.taskId || createTaskId("photo_upload"),
      operationId: target.operationId || createOperationId("photo_upload"),
    });

    setDrafts((prev) => {
      const current = prev[draftKey] || {};
      const photos = Array.isArray(current.photoFiles) ? current.photoFiles : [];
      return {
        ...prev,
        [draftKey]: {
          ...current,
          photoFiles: photos.map((item, itemIndex) =>
            itemIndex === index ? { ...item, status: "pending" } : item
          ),
        },
      };
    });

    await enqueueTasks([task]);
    setItemStatuses([itemKey], "uploading");
  }, [createMutationTask, enqueueTasks]);

  const cancelMovementEventByRow = async (rowNumber) => {
    const response = await fetch(SCRIPT_URL, {
      method: "POST",
      headers: { "Content-Type": "text/plain;charset=utf-8" },
      body: serializeRequestBody({
        action: "cancelMovementEvent",
        payload: { rowNumber },
      }),
    });

    const result = await response.json();
    if (!response.ok || result.ok === false) {
      throw new Error(result.message || "?댁뿭 ??젣 ?ㅽ뙣");
    }

    return result;
  };

  const openImageRegisterPicker = (product) => {
    const imageKey = makeProductImageMapKey({
      productCode: product?.productCode || "",
      partner: product?.partner || "",
      productName: product?.productName || "",
    });
    setSelectedImageTargetKey(imageKey);
    imageRegisterInputRef.current?.click();
  };

  const handleProductImageUpload = async (e) => {
    const file = e.target.files?.[0];
    if (!file || !selectedImageTargetKey) return;

    const targetProduct = imageRegistryProducts.find((item) => item.imageKey === selectedImageTargetKey) ||
      groupedPartners.flatMap((group) => group.products.map((product) => ({
        partner: group.partner,
        productCode: product.productCode,
        productName: product.productName,
        imageKey: makeProductImageMapKey({
          productCode: product.productCode,
          partner: group.partner,
          productName: product.productName,
        }),
      }))).find((item) => item.imageKey === selectedImageTargetKey);

    if (!targetProduct) {
      setError("?깅줉 ????곹뭹??李얠? 紐삵뻽?듬땲??");
      if (e.target) e.target.value = "";
      return;
    }

    try {
      setUploadingImageKey(selectedImageTargetKey);
      setError("");
      setMessage("");

      const encoded = await fileToBase64(file);
      const response = await fetch(SCRIPT_URL, {
        method: "POST",
        headers: { "Content-Type": "text/plain;charset=utf-8" },
        body: serializeRequestBody({
          action: "saveProductImageMapping",
          payload: {
            productCode: targetProduct.productCode || "",
            partnerName: targetProduct.partner || "",
            productName: targetProduct.productName || "",
            photo: encoded,
          },
        }),
      });

      const result = await response.json();
      if (!response.ok || result.ok === false) {
        throw new Error(result.message || "?대?吏 ?깅줉 ?ㅽ뙣");
      }

      setProductImageMap(buildProductImageMapFromRows(result.product_images));
      setToast("?대?吏 ?깅줉 ?꾨즺");
      setMessage("?곹뭹 ?대?吏媛 ?깅줉?섏뿀?듬땲??");
    } catch (err) {
      setError(err.message || "?대?吏 ?깅줉 ?ㅽ뙣");
    } finally {
      setUploadingImageKey("");
      setSelectedImageTargetKey("");
      if (e.target) e.target.value = "";
    }
  };

  const flushPending = useCallback(async () => {
    const rows = Object.values(pendingRef.current || {});
    if (!rows.length || savingRef.current) return;

    clearFlushTimer();
    savingRef.current = true;
    setSaving(true);

    try {
      const syncFlags = { hasInspection: false, hasMovement: false };
      const tasks = rows.map((row) =>
        runQueuedTask(saveQueueRef, row.key, () =>
          runWithSaveSlot(async () => {
            const { key, draftKey, uploadQueueKey, photoItems, ...rest } = row;
            const statusKeys = [key, draftKey].filter(Boolean);

            try {
              const activeUploadKey = uploadQueueKey || draftKey || key;
              if (activeUploadKey && uploadQueueRef.current[activeUploadKey]) {
                await uploadQueueRef.current[activeUploadKey];
              }

              const latestDraft = draftKey ? draftsRef.current[draftKey] || {} : {};
              const latestPhotoItems = serializePhotoItems(latestDraft.photoFiles);
              const resolvedPhotoItems = latestPhotoItems.length ? latestPhotoItems : Array.isArray(photoItems) ? photoItems : [];

              setItemStatuses(statusKeys, "saving");
              const responseData = await runWithRetry(
                async () => {
                  const saveResponse = await fetch(SCRIPT_URL, {
                    method: "POST",
                    headers: { "Content-Type": "text/plain;charset=utf-8" },
                    body: serializeRequestBody({
                      action: "saveBatch",
                      rows: [
                        {
                          ...rest,
                          ?ъ쭊?뚯씪ID紐⑸줉: resolvedPhotoItems.map((item) => item.fileId).join("\n") || rest.?ъ쭊?뚯씪ID紐⑸줉 || "",
                          photoItems: resolvedPhotoItems,
                          photoNames: resolvedPhotoItems.map((item) => item.fileName || item.name),
                        },
                      ],
                    }),
                  });
                  const payload = await saveResponse.json();
                  if (!saveResponse.ok || payload.ok === false) {
                    throw new Error(payload.message || "?? ??");
                  }
                  return payload.data || {};
                },
                async () => {
                  setItemStatuses(statusKeys, "retrying");
                }
              );

              if (Array.isArray(responseData.conflicts) && responseData.conflicts.length) {
                setConflictMap((prev) => ({
                  ...prev,
                  [key]: responseData.conflicts[0],
                }));
                setItemStatuses(statusKeys, "conflict");
                return responseData;
              }

              syncFlags.hasInspection = syncFlags.hasInspection || !!responseData.hasInspection;
              syncFlags.hasMovement = syncFlags.hasMovement || !!responseData.hasMovement;
              removePendingKeys([key]);
              retryMapRef.current[key] = null;
              setConflictMap((prev) => {
                if (!prev[key]) return prev;
                const next = { ...prev };
                delete next[key];
                return next;
              });
              setItemStatuses(statusKeys, "saved");
              return responseData;
            } catch (err) {
              retryMapRef.current[key] = row;
              setItemStatuses(statusKeys, "failed");
              setError(err.message || "?? ??");
              throw err;
            }
          })
        )
      );

      await Promise.allSettled(tasks);

      if (syncFlags.hasInspection || syncFlags.hasMovement) {
        const syncResponse = await fetch(SCRIPT_URL, {
          method: "POST",
          headers: { "Content-Type": "text/plain;charset=utf-8" },
          body: serializeRequestBody({
            action: "postSaveSync",
            payload: syncFlags,
          }),
        });
        const syncPayload = await syncResponse.json();
        if (!syncResponse.ok || syncPayload.ok === false) {
          throw new Error(syncPayload.message || "??? ??? ??");
        }
        if (Array.isArray(syncPayload.records)) {
          setHistoryRows(syncPayload.records);
        }
        if (Array.isArray(syncPayload.inspectionRows)) {
          setInspectionRows(syncPayload.inspectionRows);
        }
        if (syncPayload.summary) {
          setDashboardSummary(syncPayload.summary);
        }
      }

    } catch (err) {
      setError(err.message || "???泥섎━ ?ㅽ뙣");
    } finally {
      savingRef.current = false;
      setSaving(false);
    }
  }, [clearFlushTimer, removePendingKeys, runQueuedTask, runWithRetry, runWithSaveSlot, serializePhotoItems]);
  void flushPending;

  const flushPendingTasks = useCallback(async () => {
    const tasks = await listPendingTasks(AUTO_FLUSH_BATCH_SIZE);
    if (!tasks.length || savingRef.current) return;

    clearFlushTimer();
    savingRef.current = true;
    setSaving(true);

    try {
      const syncFlags = { hasInspection: false, hasMovement: false };

      const processTask = async (task) => {
        const payload = task.payload || {};
        const statusKeys = [task.itemKey, payload.draftKey].filter(Boolean);
        await patchTask(task.taskId, {
          status: task.type === "photo_upload" ? "uploading" : "saving",
          lastTriedAt: Date.now(),
        });
        setItemStatuses(statusKeys, task.type === "photo_upload" ? "uploading" : "saving");

        const resultData = await runWithRetry(
          async () => {
            if (task.type === "photo_upload") {
              const response = await fetch(SCRIPT_URL, {
                method: "POST",
                headers: { "Content-Type": "text/plain;charset=utf-8" },
                body: serializeRequestBody({
                  action: "uploadPhotos",
                  payload: {
                    operationId: task.operationId,
                    itemKey: task.itemKey,
                    productName: payload.productName,
                    partnerName: payload.partnerName,
                    photoKind: payload.photoKind,
                    photos: [payload.photo],
                  },
                }),
              });
              const data = await response.json();
              if (!response.ok || data.ok === false) throw new Error(data.message || "photo upload failed");
              return data.data || {};
            }

            if (task.type === "photo_meta_save") {
              const response = await fetch(SCRIPT_URL, {
                method: "POST",
                headers: { "Content-Type": "text/plain;charset=utf-8" },
                body: serializeRequestBody({
                  action: "savePhotoMeta",
                  payload: { ...payload, operationId: task.operationId },
                }),
              });
              const data = await response.json();
              if (!response.ok || data.ok === false) throw new Error(data.message || "photo meta save failed");
              return data.data || {};
            }

            const response = await fetch(SCRIPT_URL, {
              method: "POST",
              headers: { "Content-Type": "text/plain;charset=utf-8" },
              body: serializeRequestBody({
                action: "saveBatch",
                rows: [{ ...payload, operationId: task.operationId }],
              }),
            });
            const data = await response.json();
            if (!response.ok || data.ok === false) throw new Error(data.message || "save failed");
            return data.data || {};
          },
          async () => {
            await patchTask(task.taskId, {
              status: "retry",
              retryCount: Number(task.retryCount || 0) + 1,
              lastTriedAt: Date.now(),
            });
            setItemStatuses(statusKeys, "retrying");
          }
        );

        if (task.type === "photo_upload") {
          const uploadedPhoto = createUploadedPhotoItem({
            ...(Array.isArray(resultData.photos) ? resultData.photos[0] : {}),
            photoKind: payload.photoKind,
          });

          setDrafts((prev) => {
            const currentDraft = prev[payload.draftKey] || {};
            const currentPhotos = Array.isArray(currentDraft.photoFiles) ? currentDraft.photoFiles : [];
            const nextPhotos = currentPhotos.map((item) => (item?.localId === payload.localId ? uploadedPhoto : item));
            return {
              ...prev,
              [payload.draftKey]: {
                ...currentDraft,
                photoFiles: nextPhotos,
                photoNames: nextPhotos.map((photo) => photo.fileName || photo.name),
              },
            };
          });

          const draftContext = draftsRef.current[payload.draftKey]?.__photoContext || {};
          await enqueueTasks([
            createMutationTask(
              "photo_meta_save",
              task.itemKey,
              buildPhotoMetaTaskPayload({
                itemKey: task.itemKey,
                draftKey: payload.draftKey,
                product: {
                  productCode: draftContext.productCode || payload.productCode || "",
                  productName: payload.productName || "",
                  partner: payload.partnerName || "",
                },
                centerName: draftContext.centerName || "",
                photoKind: payload.photoKind,
                action: "append",
                uploadedPhoto,
              })
            ),
          ]);
        } else if (Array.isArray(resultData.conflicts) && resultData.conflicts.length) {
          setConflictMap((prev) => ({
            ...prev,
            [task.itemKey]: resultData.conflicts[0],
          }));
          await patchTask(task.taskId, { status: "conflict", serverResponse: resultData });
          setItemStatuses(statusKeys, "conflict");
          return;
        } else {
          syncFlags.hasInspection = syncFlags.hasInspection || !!resultData.hasInspection || task.type === "qty_update";
          syncFlags.hasMovement =
            syncFlags.hasMovement ||
            !!resultData.hasMovement ||
            task.type === "return_update" ||
            task.type === "exchange_update" ||
            task.type === "photo_meta_save";
          setConflictMap((prev) => {
            if (!prev[task.itemKey]) return prev;
            const next = { ...prev };
            delete next[task.itemKey];
            return next;
          });
        }

        await patchTask(task.taskId, { status: "completed", serverResponse: resultData });
        await removeTask(task.taskId);
        setItemStatuses(statusKeys, "saved");
      };

      await Promise.allSettled(
        tasks.map((task) => runQueuedTask(saveQueueRef, task.itemKey, () => runWithSaveSlot(() => processTask(task))))
      );

      if (syncFlags.hasInspection || syncFlags.hasMovement) {
        try {
          const syncResponse = await fetch(SCRIPT_URL, {
            method: "POST",
            headers: { "Content-Type": "text/plain;charset=utf-8" },
            body: serializeRequestBody({
              action: "postSaveSync",
              payload: syncFlags,
            }),
          });
          const syncPayload = await syncResponse.json();
          if (syncResponse.ok && syncPayload.ok !== false) {
            if (Array.isArray(syncPayload.records)) setHistoryRows(syncPayload.records);
            if (Array.isArray(syncPayload.inspectionRows)) setInspectionRows(syncPayload.inspectionRows);
            if (syncPayload.summary) setDashboardSummary(syncPayload.summary);
          }
        } catch (_) {}
      }

      await clearCompletedTasks();
      await refreshPendingFromQueue();
    } catch (err) {
      setError(err.message || "????湲곗뿴 泥섎━ ?ㅽ뙣");
    } finally {
      savingRef.current = false;
      setSaving(false);
    }
  }, [buildPhotoMetaTaskPayload, clearFlushTimer, createMutationTask, enqueueTasks, refreshPendingFromQueue, runQueuedTask, runWithRetry, runWithSaveSlot]);

  useEffect(() => {
    pendingRef.current = pendingMap;
  }, [pendingMap]);

  useEffect(() => {
    clearFlushTimer();
    return () => clearFlushTimer();
  }, [pendingMap, clearFlushTimer]);

  const saveInspectionQtySimple = async (product) => {
    const draftKey = `inspection||${product.partner}||${product.productCode}`;
    const qty = parseQty(drafts[draftKey]?.inspectionQty);
    const photoFiles = Array.isArray(drafts[draftKey]?.photoFiles) ? drafts[draftKey].photoFiles : [];

    if (qty <= 0 && !photoFiles.length) {
      setError("寃?덉닔???먮뒗 ?ъ쭊???낅젰??二쇱꽭??");
      return;
    }

    setError("");
    setMessage("");
    const nextEntry = buildInspectionPendingEntry(product, drafts[draftKey] || {});

    console.log("[saveInspectionQtySimple] pending entry", {
      jobKey: nextEntry.?묒뾽湲곗??쇰삉?봀SV?앸퀎媛?
      productCode: nextEntry.?곹뭹肄붾뱶,
      partnerName: nextEntry.?묐젰?щ챸,
      centerName: nextEntry.?쇳꽣紐?
      inspectionQty: nextEntry.寃?덉닔??
      returnQty: nextEntry.?뚯넚?섎웾,
      exchangeQty: nextEntry.援먰솚?섎웾,
      totalQty: nextEntry.?꾩껜諛쒖＜?섎웾,
      orderQty: nextEntry.諛쒖＜?섎웾,
      photosCount: Array.isArray(nextEntry.photoItems) ? nextEntry.photoItems.length : 0,
    });

    await enqueueTasks([createMutationTask("qty_update", nextEntry.key, nextEntry)]);
    
  };

  const saveReturnExchange = async (product, centerName) => {
    if (!product.centers.find((item) => item.center === centerName)) {
      setError("?쇳꽣瑜??좏깮??二쇱꽭??");
      return;
    }

    const draftKey = `return||${product.partner}||${product.productCode}||${centerName}`;
    const draft = drafts[draftKey] || {};
    const returnQty = parseQty(draft.returnQty);
    const exchangeQty = parseQty(draft.exchangeQty);

    if (!currentJob?.job_key) {
      setError("???媛?ν븳 ?묒뾽 湲곗? CSV媛 ?놁뒿?덈떎.");
      return;
    }

    if (returnQty <= 0 && exchangeQty <= 0) {
      setError("?뚯넚?섎웾 ?먮뒗 援먰솚?섎웾???낅젰??二쇱꽭??");
      return;
    }

    setError("");
    setMessage("");

    const movementEntries = buildMovementEntries(product, centerName, draft);

    console.log(
      "[saveReturnExchange] pending entries",
      movementEntries.map((entry) => ({
        movementType: entry.movementType,
        jobKey: entry.?묒뾽湲곗??쇰삉?봀SV?앸퀎媛?
        productCode: entry.?곹뭹肄붾뱶,
        partnerName: entry.?묐젰?щ챸,
        centerName: entry.?쇳꽣紐?
        returnQty: entry.?뚯넚?섎웾,
        exchangeQty: entry.援먰솚?섎웾,
        totalQty: entry.?꾩껜諛쒖＜?섎웾,
        orderQty: entry.諛쒖＜?섎웾,
        photosCount: Array.isArray(entry.photoItems) ? entry.photoItems.length : 0,
      }))
    );

    await enqueueTasks(
      movementEntries.map((entry) =>
        createMutationTask(
          entry.movementType === "RETURN" ? "return_update" : "exchange_update",
          entry.key,
          entry
        )
      )
    );
    
  };

  const deleteHistoryRecord = async (record) => {
    const rowNumber = Number(record.__rowNumber || 0);
    if (!rowNumber) {
      setError("??젣?????뺣낫瑜?李얠? 紐삵뻽?듬땲??");
      return;
    }

    const ok = window.confirm("???댁뿭????젣?좉퉴??");
    if (!ok) return;

    try {
      setDeletingRowNumber(rowNumber);
      const result = await cancelMovementEventByRow(rowNumber);
      if (Array.isArray(result?.records)) {
        setHistoryRows(result.records);
      } else {
        setHistoryRows((prev) => prev.filter((item) => Number(item.__rowNumber) !== rowNumber));
      }
      if (Array.isArray(result?.inspectionRows)) {
        setInspectionRows(result.inspectionRows);
      }
      setToast("??젣 ?꾨즺");
    } catch (err) {
      setError(err.message || "?댁뿭 ??젣 ?ㅽ뙣");
    } finally {
      setDeletingRowNumber(null);
    }
  };

  const downloadPhotoZip = async (mode) => {
    try {
      setZipDownloading(mode);
      setError("");
      setMessage("");

      const response = await fetch(SCRIPT_URL, {
        method: "POST",
        headers: { "Content-Type": "text/plain;charset=utf-8" },
        body: serializeRequestBody({
          action: "downloadPhotoZip",
          payload: { mode },
        }),
      });

      const result = await response.json();
      if (!response.ok || result.ok === false) {
        throw new Error(result.message || "ZIP ?ㅼ슫濡쒕뱶 ?ㅽ뙣");
      }

      if (Array.isArray(result.files) && result.files.length > 0) {
        result.files.forEach((file, index) => {
          if (!file?.downloadUrl) return;
          const link = document.createElement("a");
          link.href = file.downloadUrl;
          link.target = "_blank";
          link.rel = "noreferrer";
          link.download = file.fileName || "";
          document.body.appendChild(link);
          window.setTimeout(() => {
            link.click();
            link.remove();
          }, index * 180);
        });
        setToast(result.files.length > 1 ? `ZIP ${result.files.length}媛?遺꾪븷 ?ㅼ슫濡쒕뱶 以鍮??꾨즺` : "ZIP ?ㅼ슫濡쒕뱶 以鍮??꾨즺");
        return;
      }

      if (result.downloadUrl) {
        const link = document.createElement("a");
        link.href = result.downloadUrl;
        link.target = "_blank";
        link.rel = "noreferrer";
        link.download = result.fileName || "";
        document.body.appendChild(link);
        link.click();
        link.remove();
      setToast("ZIP ?ㅼ슫濡쒕뱶 以鍮??꾨즺");
        return;
      }

      if (!result.zipBase64) {
        setToast("?ㅼ슫濡쒕뱶 媛?ν븳 ?ъ쭊???놁뒿?덈떎.");
        return;
      }

      const blob = base64ToBlob(result.zipBase64, result.mimeType || "application/zip");
      const link = document.createElement("a");
      const href = URL.createObjectURL(blob);
      const fileName = result.fileName ||
        (mode === "movement"
          ? `?뚯넚_援먰솚_?ъ쭊_${formatDateForFileName()}.zip`
          : mode === "inspection"
          ? `寃?덉궗吏?${formatDateForFileName()}.zip`
          : `李쎄퀬?ъ쭊_${formatDateForFileName()}.zip`);

      link.href = href;
      link.download = fileName;
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(href);
      setToast("ZIP ?ㅼ슫濡쒕뱶 ?꾨즺");
    } catch (err) {
      setError(err.message || "ZIP ?ㅼ슫濡쒕뱶 ?ㅽ뙣");
    } finally {
      setZipDownloading("");
    }
  };

  const resetCurrentJobInputs = async () => {
    if (!currentJob?.job_key) {
      setError("珥덇린?뷀븷 ?꾩옱 ?묒뾽???놁뒿?덈떎.");
      return;
    }

    if (!adminPassword.trim()) {
      setError("愿由ъ옄 鍮꾨?踰덊샇瑜??낅젰??二쇱꽭??");
      return;
    }

    try {
      setAdminResetting(true);
      setError("");
      setMessage("");

      const response = await fetch(SCRIPT_URL, {
        method: "POST",
        headers: { "Content-Type": "text/plain;charset=utf-8" },
        body: serializeRequestBody({
          action: "resetCurrentJobInputData",
          payload: {
            jobKey: currentJob.job_key,
            password: adminPassword.trim(),
          },
        }),
      });

      const result = await response.json();
      if (!response.ok || result.ok === false) {
        throw new Error(result.message || "珥덇린???ㅽ뙣");
      }

      clearFlushTimer();
      savingRef.current = false;
      pendingRef.current = {};
      setSaving(false);
      setPendingMap({});
      setItemStatusMap({});
      setDrafts({});
      setHistoryRows(Array.isArray(result.records) ? result.records : []);
      setInspectionRows(Array.isArray(result.inspectionRows) ? result.inspectionRows : []);
      setShowAdminReset(false);
      setAdminPassword("");
      await loadBootstrap();
      if (result.summary) {
        setDashboardSummary(result.summary);
      }
      setToast("?꾩옱 ?묒뾽 ?낅젰 ?곗씠??珥덇린???꾨즺");
    } catch (err) {
      setError(err.message || "珥덇린???ㅽ뙣");
    } finally {
      setAdminResetting(false);
    }
  };

  const handleHappycallCsvUpload = async (e) => {
    const file = e.target.files?.[0];
    if (!file) return;

    try {
      setUploadingHappycallCsv(true);
      setError("");
      setMessage("");

      const parsedRows = await parseHappycallSourceFile(file);

      const rawRows = (parsedRows || [])
        .map((row) => ({
          ?쒕ぉ: clampText(row["?쒕ぉ"] || row["subject"] || "", 300),
          蹂몃Ц: clampText(row["蹂몃Ц"] || row["body"] || row["?댁슜(蹂댄샇)"] || "", 8000),
          硫붿씪ID: clampText(row["?ㅻ뜑媛?硫붿떆吏 ID"] || row["硫붿씪ID"] || row["?묒닔踰덊샇"] || "", 200),
          蹂대궦?대챸: clampText(row["蹂대궦?대챸:(?대쫫)"] || row["senderName"] || "", 200),
          ?묒닔?쇱떆: clampText(row["?묒닔?쇱떆"] || row["receivedAt"] || "", 100),
          ?묐젰?? clampText(row["泥섎━?묐젰??] || row["?묐젰??] || row["?묐젰?щ챸"] || "", 200),
          ?좏삎: clampText(
            row["?좏삎(?)"] || row["?좏삎(以?"] || row["?좏삎(??"] || row["?좏삎"] || "",
            200
          ),
        }))
        .filter((row) => String(row.?쒕ぉ || "").trim() || String(row.蹂몃Ц || "").trim());

      const dedupedMap = new Map();
      rawRows.forEach((row) => {
        const dedupeKey = [
          String(row.硫붿씪ID || "").trim(),
          String(row.?묐젰??|| "").trim(),
          String(row.?묒닔?쇱떆 || "").trim(),
          String(row.?쒕ぉ || "").trim(),
          String(row.蹂몃Ц || "").trim().slice(0, 300),
        ].join("||");
        dedupedMap.set(dedupeKey, row);
      });

      const rows = Array.from(dedupedMap.values());
      const skippedCount = Math.max(0, rawRows.length - rows.length);

      if (!rows.length) {
        throw new Error("?댄뵾肄?CSV?먯꽌 媛?몄삱 ???덈뒗 ?됱씠 ?놁뒿?덈떎.");
      }

      const batchSize = rows.length >= 1500 ? 500 : 300;
      const totalBatches = Math.ceil(rows.length / batchSize);
      let lastResult = null;
      let insertedTotal = 0;
      let updatedTotal = 0;

      for (let index = 0; index < rows.length; index += batchSize) {
        const batchRows = rows.slice(index, index + batchSize);
        const batchNumber = Math.floor(index / batchSize) + 1;
        const processedCount = Math.min(index + batchRows.length, rows.length);
        setMessage(
          `?댄뵾肄?CSV 泥섎━ 以?.. ${batchNumber}/${totalBatches} 諛곗튂 (${processedCount} / ${rows.length})`
        );

        const response = await fetch(SCRIPT_URL, {
          method: "POST",
          headers: { "Content-Type": "text/plain;charset=utf-8" },
          body: serializeRequestBody({
            action: "importHappycallCsv",
            rows_base64: batchRows.map((row) => encodeBase64Utf8(JSON.stringify(row))),
          }),
        });

        const result = await response.json();
        if (!response.ok || result.ok === false) {
          throw new Error(
            result.message || `?댄뵾肄?CSV 媛?몄삤湲곗뿉 ?ㅽ뙣?덉뒿?덈떎. (${batchNumber}/${totalBatches} 諛곗튂)`
          );
        }

        lastResult = result;
        insertedTotal += Number(result?.data?.inserted || 0);
        updatedTotal += Number(result?.data?.updated || 0);
      }

      setHappycallAnalytics(lastResult?.happycall || {});
      setMessage("");
      setToast(
        `?댄뵾肄?CSV 諛섏쁺 ?꾨즺 쨌 ?좉퇋 ${insertedTotal}嫄?쨌 媛깆떊 ${updatedTotal}嫄?{
          skippedCount > 0 ? ` 쨌 以묐났 ?쒖쇅 ${skippedCount}嫄? : ""
        }`
      );
    } catch (err) {
      setError(
        `${err.message || "?댄뵾肄?CSV 媛?몄삤湲곗뿉 ?ㅽ뙣?덉뒿?덈떎."} 媛숈? CSV瑜??ㅼ떆 ?щ━硫??댁뼱??諛섏쁺?⑸땲??`
      );
    } finally {
      setUploadingHappycallCsv(false);
      if (e.target) {
        e.target.value = "";
      }
    }
  };

  const effectiveSheetUrl =
    worksheetUrl ||
    "https://docs.google.com/spreadsheets/d/1ZB9Y-3_03NZ0Gyydfi4xzDbZQz6O62kabQpI7dkLGBc/edit?pli=1&gid=634559028#gid=634559028";

  return (
    <>
      <input
        ref={fileInputRef}
        type="file"
        accept=".csv"
        onChange={handleCsvUpload}
        style={styles.hiddenInput}
      />
      <input
        ref={happycallFileInputRef}
        type="file"
        accept=".csv,.xls,.xlsx"
        onChange={handleHappycallCsvUpload}
        style={styles.hiddenInput}
      />
      <input
        ref={imageRegisterInputRef}
        type="file"
        accept="image/*"
        onChange={handleProductImageUpload}
        style={styles.hiddenInput}
      />

      <ReferenceFunctionalApp
        activeTab={activeTab}
        onTabChange={async (nextTab) => {
          setActiveTab(nextTab);
          if (nextTab === "records") {
            await loadHistoryRows();
          }
        }}
        onCsvUploadClick={() => fileInputRef.current?.click()}
        onHappycallUploadClick={() => happycallFileInputRef.current?.click()}
        onOpenSheet={() => window.open(effectiveSheetUrl, "_blank", "noopener,noreferrer")}
        onSummaryAction={() => setActiveTab("analytics")}
        sheetUrl={effectiveSheetUrl}
        uploadingCsv={uploadingCsv}
        uploadingHappycallCsv={uploadingHappycallCsv}
        currentFileName={currentFileName}
        message={message}
        error={error}
        search={search}
        onSearchChange={setSearch}
        onScannerOpen={() => setIsScannerOpen(true)}
        onRefreshRecords={loadHistoryRows}
        onFlushPending={flushPendingTasks}
        renderRecordsView={renderRecordsView}
        groupedPartners={groupedPartners}
        expandedPartner={expandedPartner}
        onTogglePartner={(partner) => setExpandedPartner((prev) => (prev === partner ? "" : partner))}
        renderProductRow={(partnerGroup, product, variant = "web") => {
          const productStateKey = `${product.partner}||${product.productCode}`;
          const historyCounts = historyCountMap[`${product.partner}||${product.productCode}`] || {
            returnCount: 0,
            exchangeCount: 0,
          };
          const historySummary = [
            historyCounts.returnCount > 0 ? `?뚯넚 ${historyCounts.returnCount}` : "",
            historyCounts.exchangeCount > 0 ? `援먰솚 ${historyCounts.exchangeCount}` : "",
          ]
            .filter(Boolean)
            .join(" / ");
          const isOpen = expandedProductCode === productStateKey;
          const selectedCenter = selectedCenterByProduct[productStateKey] || product.centers[0]?.center || "";
          const selectedCenterInfo = product.centers.find((item) => item.center === selectedCenter) || null;
          const inspectionDraftKey = `inspection||${product.partner}||${product.productCode}`;
          const movementDraftKey = `return||${product.partner}||${product.productCode}||${selectedCenter}`;
          const inspectionDraft = drafts[inspectionDraftKey] || {};
          const movementDraft = drafts[movementDraftKey] || {};
          const entityKey = makeEntityKey(currentJob?.job_key, product.productCode, product.partner);
          const inspectionSaved = inspectionSavedMap[entityKey] || { inspectionQty: 0, returnQty: 0, exchangeQty: 0 };
          const returnSavedKey = makeMovementPendingKey("RETURN", currentJob?.job_key, product.productCode, product.partner, selectedCenter);
          const exchangeSavedKey = makeMovementPendingKey("EXCHANGE", currentJob?.job_key, product.productCode, product.partner, selectedCenter);
          const returnSavedQty = parseQty(movementSavedMap[returnSavedKey]?.returnQty);
          const exchangeSavedQty = parseQty(movementSavedMap[exchangeSavedKey]?.exchangeQty);
          const movementSavedMeta = movementSavedMap[returnSavedKey] || movementSavedMap[exchangeSavedKey] || null;
          const inspectionInputQty = parseQty(inspectionDraft.inspectionQty);
          const returnInputQty = parseQty(movementDraft.returnQty);
          const exchangeInputQty = parseQty(movementDraft.exchangeQty);
          const inspectionPreviewText = `?꾩옱 ${inspectionSaved.inspectionQty}媛?/ ?낅젰 ${inspectionInputQty}媛?/ ??μ삁??${inspectionInputQty || inspectionSaved.inspectionQty}媛?;
          const returnPreviewText = `?꾩옱 ${returnSavedQty}媛?/ ?낅젰 ${returnInputQty}媛?/ ?꾩쟻?덉젙 ${returnSavedQty + returnInputQty}媛?;
          const exchangePreviewText = `?꾩옱 ${exchangeSavedQty}媛?/ ?낅젰 ${exchangeInputQty}媛?/ ?꾩쟻?덉젙 ${exchangeSavedQty + exchangeInputQty}媛?;
          const inspectionStatus = itemStatusMap[inspectionDraftKey] || itemStatusMap[entityKey];
          const movementStatus = itemStatusMap[movementDraftKey];
          const actionStatus = mode === "inspection" ? inspectionStatus : movementStatus;
          const rawLockInfo = lockMap[productStateKey] || null;
          const lockInfo = rawLockInfo ? { ...rawLockInfo, isMine: rawLockInfo.editorId === editorProfile.editorId } : null;
          const conflictInfo =
            mode === "inspection"
              ? conflictMap[entityKey] || null
              : conflictMap[returnSavedKey] || conflictMap[exchangeSavedKey] || null;

          return (
            <ProductRow
              key={`${partnerGroup.partner}-${product.productCode}`}
              variant={variant}
              mode={mode}
              product={product}
              productStateKey={productStateKey}
              historySummary={historySummary}
              isOpen={isOpen}
              selectedCenter={selectedCenter}
              selectedCenterInfo={selectedCenterInfo}
              inspectionDraft={inspectionDraft}
              movementDraft={movementDraft}
              inspectionDraftKey={inspectionDraftKey}
              movementDraftKey={movementDraftKey}
              entityKey={entityKey}
              inspectionSaved={inspectionSaved}
              movementSavedMeta={movementSavedMeta}
              returnSavedQty={returnSavedQty}
              exchangeSavedQty={exchangeSavedQty}
              inspectionPreviewText={inspectionPreviewText}
              returnPreviewText={returnPreviewText}
              exchangePreviewText={exchangePreviewText}
              actionStatus={actionStatus}
              actionStatusLabel={getStatusLabel(actionStatus)}
              happycallBadges={[]}
              styles={styles}
              ProductImage={ProductImage}
              DraftPhotoPreviewList={DraftPhotoPreviewList}
              getHappycallRankStyle={getHappycallRankStyle}
              setExpandedProductCode={setExpandedProductCode}
              setSelectedCenterByProduct={setSelectedCenterByProduct}
              setDrafts={setDrafts}
              saveInspectionQtySimple={saveInspectionQtySimple}
              uploadDraftPhotos={uploadDraftPhotos}
              removeDraftPhoto={removeDraftPhoto}
              retryDraftPhotoUpload={retryDraftPhotoUpload}
              saveReturnExchange={saveReturnExchange}
              setItemStatusMap={setItemStatusMap}
              lockInfo={lockInfo}
              conflictInfo={conflictInfo}
            />
          );
        }}
        saveQueueItems={saveQueueItems.map((item) => ({ ...item, status: getStatusLabel(item.status) }))}
        totalVisibleProducts={totalVisibleProducts}
        historyRows={historyRows}
        historyLoading={historyLoading}
        analyticsKpis={analyticsKpis}
        selectedHappycallPeriod={selectedHappycallPeriod}
        onSelectPeriod={setSelectedHappycallPeriod}
        happycallHeroCard={happycallHeroCard}
        happycallMiniCards={happycallMiniCards}
        onDownloadInspectionZip={() => downloadPhotoZip("inspection")}
        onDownloadMovementZip={() => downloadPhotoZip("movement")}
        zipDownloading={zipDownloading}
      />

      {zoomPhotoUrl && (
        <div style={styles.photoOverlay} onClick={() => setZoomPhotoUrl("")}>
          <img src={zoomPhotoUrl} alt="?뺣? ?ъ쭊" style={styles.photoZoom} />
        </div>
      )}

      {isScannerOpen && (
        <div style={styles.scannerOverlay} onClick={closeScanner}>
          <div style={styles.scannerModal} onClick={(e) => e.stopPropagation()}>
            <button type="button" onClick={closeScanner} style={styles.scannerCloseBtn}>
              ??
            </button>
            <div style={styles.scannerTopText}>{scannerReady ? scannerStatus : "諛붿퐫???몄떇 以?.."}</div>
            <div style={styles.scannerViewport}>
              <video ref={scannerVideoRef} style={styles.scannerVideo} muted playsInline />
              <div style={styles.scannerGuideBox} />
            </div>
            <div style={styles.scannerHelperText}>諛붿퐫?쒕? ?붾㈃ 以묒븰??留욎떠 二쇱꽭??</div>
            {scannerError ? <div style={styles.errorBox}>{scannerError}</div> : null}
            <div style={styles.scannerActions}>
              {torchSupported ? (
                <button type="button" onClick={toggleTorch} style={styles.secondaryButton}>
                  {torchOn ? "?뚮옒???꾧린" : "?뚮옒??耳쒓린"}
                </button>
              ) : null}
              <button
                type="button"
                onClick={() => {
                  closeScanner();
                  focusSearchInput();
                }}
                style={styles.primaryButton}
              >
                吏곸젒 ?낅젰
              </button>
            </div>
          </div>
        </div>
      )}

      {toast ? <div style={styles.toast}>{toast}</div> : null}
    </>
  );

  // eslint-disable-next-line no-unreachable
  return (
    <div style={styles.app}>
      <input
        ref={fileInputRef}
        type="file"
        accept=".csv"
        onChange={handleCsvUpload}
        style={styles.hiddenInput}
      />
        <input
          ref={happycallFileInputRef}
          type="file"
          accept=".csv,.xls,.xlsx"
          onChange={handleHappycallCsvUpload}
          style={styles.hiddenInput}
        />
        <input
          ref={imageRegisterInputRef}
          type="file"
          accept="image/*"
          onChange={handleProductImageUpload}
          style={styles.hiddenInput}
        />

      <div style={styles.headerCard}>
        <div style={styles.headerTopRow}>
          <div style={styles.brandBlock}>
            <div style={styles.brandRow}>
              <h1 style={styles.title}>{"\uAC80\uD488 \uC2DC\uC2A4\uD15C"}</h1>
              <span style={styles.headerModeBadge}>{"\uAC1C\uC120 \uC124\uACC4\uB3C4"}</span>
            </div>
          </div>
          <div style={styles.processFlow}>
            <div style={styles.processStep}>{"CSV \uC5C5\uB85C\uB4DC"}</div>
            <div style={styles.processArrow}>{"\u2192"}</div>
            <div style={styles.processStep}>{"\uAC80\uD488 \uC785\uB825"}</div>
            <div style={styles.processArrow}>{"\u2192"}</div>
            <div style={styles.processStep}>{"\uB0B4\uC5ED \uC870\uD68C"}</div>
            <div style={styles.processArrow}>{"\u2192"}</div>
            <div style={styles.processStep}>{"\uD1B5\uACC4"}</div>
          </div>
        </div>
      </div>

      <div style={styles.panel}>
        <div style={styles.tabRow}>
          <button
            type="button"
            onClick={() => setActiveTab("inspection")}
            style={{ ...styles.tabButton, ...(activeTab === "inspection" ? styles.tabButtonActive : {}) }}
          >
            {"1. \uAC80\uD488"}
          </button>
          <button
            type="button"
            onClick={async () => {
              setActiveTab("records");
              await loadHistoryRows();
            }}
            style={{ ...styles.tabButton, ...(activeTab === "records" ? styles.tabButtonActive : {}) }}
          >
            {"2. \uB0B4\uC5ED"}
          </button>
          <button
            type="button"
            onClick={() => setActiveTab("analytics")}
            style={{ ...styles.tabButton, ...(activeTab === "analytics" ? styles.tabButtonActive : {}) }}
          >
            {"3. \uD1B5\uACC4"}
          </button>
