  const renderRecordsView = useCallback(() => (
    <div style={{ display: "grid", gridTemplateColumns: recordDetailDraft && window.innerWidth > 1180 ? "minmax(0,1fr) minmax(320px, 380px)" : "minmax(0,1fr)", gap: 14, alignItems: "start" }}>
      <div style={{ display: "grid", gap: 12 }}>
