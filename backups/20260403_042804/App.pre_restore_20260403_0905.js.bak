  const [lockMap, setLockMap] = useState({});

  const [excludedProductCodes, setExcludedProductCodes] = useState(new Set());
  const [excludedPairKeys, setExcludedPairKeys] = useState(new Set());
  const [eventMap, setEventMap] = useState({});
  const [reservationRows, setReservationRows] = useState([]);
  const [dashboardSummary, setDashboardSummary] = useState({});
  const [happycallAnalytics, setHappycallAnalytics] = useState({});
  const [selectedHappycallPeriod, setSelectedHappycallPeriod] = useState("1d");

  const [showHistory, setShowHistory] = useState(false);
  const [historyLoading, setHistoryLoading] = useState(false);
  const [historyRows, setHistoryRows] = useState([]);
  const [inspectionRows, setInspectionRows] = useState([]);
  const [recordDetailKey, setRecordDetailKey] = useState("");
  const [recordDetailDraft, setRecordDetailDraft] = useState(null);
  const [recordDetailSaving, setRecordDetailSaving] = useState(false);
  const [zoomPhotoUrl, setZoomPhotoUrl] = useState("");
  const [zipDownloading, setZipDownloading] = useState("");
  const [showAdminReset, setShowAdminReset] = useState(false);
  const [adminPassword, setAdminPassword] = useState("");
  const [adminResetting, setAdminResetting] = useState(false);
  const [uploadingHappycallCsv, setUploadingHappycallCsv] = useState(false);
  const [productImageMap, setProductImageMap] = useState({});
  const [showImageRegister, setShowImageRegister] = useState(false);
  const [imageRegisterSearch, setImageRegisterSearch] = useState("");
  const [selectedImageTargetKey, setSelectedImageTargetKey] = useState("");
  const [uploadingImageKey, setUploadingImageKey] = useState("");
  const [showSaveStatusPanel, setShowSaveStatusPanel] = useState(false);

  const [isScannerOpen, setIsScannerOpen] = useState(false);
  const [scannerError, setScannerError] = useState("");
  const [scannerStatus, setScannerStatus] = useState("燁삳?李??? 餓Β??쑵釉????됰뮸??덈뼄...");
  const [scannerReady, setScannerReady] = useState(false);
  const [torchSupported, setTorchSupported] = useState(false);
  const [torchOn, setTorchOn] = useState(false);

  const fileInputRef = useRef(null);
  const happycallFileInputRef = useRef(null);
  const imageRegisterInputRef = useRef(null);
  const searchInputRef = useRef(null);
  const scannerVideoRef = useRef(null);
  const scannerControlsRef = useRef(null);
  const scannerTrackRef = useRef(null);
  const scannerStatusTimerRef = useRef(null);
  const draftsRef = useRef({});
  const pendingRef = useRef({});
  const activeLockKeyRef = useRef("");
  const saveQueueRef = useRef({});
  const uploadQueueRef = useRef({});
  const retryMapRef = useRef({});
  const activeSaveCountRef = useRef(0);
  const savingRef = useRef(false);
  const flushTimerRef = useRef(null);

  useEffect(() => {
    if (!toast) return undefined;
    const timer = setTimeout(() => setToast(""), 1800);
    return () => clearTimeout(timer);
  }, [toast]);

  const clearFlushTimer = useCallback(() => {
    if (flushTimerRef.current) {
      clearTimeout(flushTimerRef.current);
      flushTimerRef.current = null;
    }
  }, []);

  useEffect(() => () => clearFlushTimer(), [clearFlushTimer]);

  const makeEntityKey = (jobKey, productCode, partnerName) =>
    [jobKey || "", productCode || "", partnerName || ""].join("||");

  const makeMovementPendingKey = (movementType, jobKey, productCode, partnerName, centerName) =>
    [
      "movement",
      movementType || "",
      jobKey || "",
      productCode || "",
      partnerName || "",
      centerName || "",
    ].join("||");

  const getStatusLabel = (status) => {
    if (status === "editing") return "?낅젰以?;
    if (status === "pending") return "??λ?湲?;
    if (status === "uploading") return "?낅줈?쒖쨷";
    if (status === "saving") return "??μ쨷";
    if (status === "retrying") return "?ъ떆?꾩쨷";
    if (status === "saved") return "??μ셿猷?;
    if (status === "conflict") return "異⑸룎";
    if (status === "failed") return "?쇰??ㅽ뙣";
    return "";
  };

  const getStatusProgress = (status) => {
    if (status === "editing") return 10;
    if (status === "pending") return 15;
    if (status === "uploading") return 45;
    if (status === "retrying") return 60;
    if (status === "saving") return 80;
    if (status === "saved") return 100;
    if (status === "conflict") return 100;
    if (status === "failed") return 100;
    return 0;
  };

  const buildQueueItemTitle = useCallback((entry) => {
    if (!entry) return "";
    const partner = String(entry["?묐젰?щ챸"] || entry.partnerName || "").trim();
    const productName = String(entry["?곹뭹紐?] || entry.productName || "").trim();
    const movementType = String(entry.movementType || "").trim().toUpperCase();
    const typeLabel =
      entry.type === "inspection"
        ? "寃??
        : movementType === "RETURN"
        ? "?뚯넚"
        : movementType === "EXCHANGE"
        ? "援먰솚"
        : "???;

    return [partner, productName, typeLabel].filter(Boolean).join(" - ");
  }, []);

  const serializePhotoItems = useCallback(
    (items) =>
      (Array.isArray(items) ? items : [])
        .filter(isUploadedPhotoItem)
        .map((item) => createUploadedPhotoItem(item)),
    []
  );

  const persistDrafts = useCallback((nextDrafts) => {
    try {
      const serializable = Object.fromEntries(
        Object.entries(nextDrafts || {}).map(([key, value]) => [
          key,
          {
            ...value,
            photoFiles: serializePhotoItems(value?.photoFiles),
            photoNames: Array.isArray(value?.photoNames) ? value.photoNames : [],
          },
        ])
      );
      savePersistedState(DRAFT_STORAGE_KEY, serializable).catch(() => undefined);
    } catch (_) {}
  }, [serializePhotoItems]);

  const persistPending = useCallback((nextPending) => {
    try {
      const serializable = Object.fromEntries(
        Object.entries(nextPending || {}).map(([key, value]) => [
          key,
          {
            ...value,
            photoFiles: undefined,
            photoItems: serializePhotoItems(value?.photoItems || value?.photoFiles),
          },
        ])
      );
      savePersistedState(PENDING_STORAGE_KEY, serializable).catch(() => undefined);
    } catch (_) {}
  }, [serializePhotoItems]);

  const buildPendingMapFromTasks = useCallback((tasks) => {
    const next = {};

    (Array.isArray(tasks) ? tasks : []).forEach((task) => {
      if (!task || ["completed", "cancelled"].includes(String(task.status || ""))) return;
      const payload = task.payload || {};
      const key = String(task.itemKey || payload.key || "").trim();
      if (!key) return;

      next[key] = {
        ...(next[key] || {}),
        ...payload,
        key,
        taskId: task.taskId,
        operationId: task.operationId,
        type: task.type,
      };
    });

    return next;
  }, []);

  const recordPerformance = useCallback((kind, label, timings = {}, meta = {}) => {
    const normalizedTimings = Object.fromEntries(
      Object.entries(timings || {}).filter(([, value]) => Number.isFinite(Number(value)))
    );

    const entry = {
      id: `${kind}-${Date.now()}-${Math.random().toString(16).slice(2, 8)}`,
      kind,
      label,
      timings: normalizedTimings,
      meta,
      createdAt: new Date().toISOString(),
    };

    setPerformanceLog((prev) => [entry, ...prev].slice(0, 18));
    return entry;
  }, []);

  const mergeDraftsFromQueue = useCallback((tasks) => {
    const nextDrafts = {};

    (Array.isArray(tasks) ? tasks : []).forEach((task) => {
      if (!task || task.type !== "photo_upload") return;
      const payload = task.payload || {};
      const draftKey = String(payload.draftKey || "").trim();
      if (!draftKey || !payload.photo?.imageBase64) return;

      const localPhoto = createLocalPhotoItem(null, {
        localId: payload.localId,
        photoKind: payload.photoKind,
        status: String(task.status || "pending"),
        imageBase64: payload.photo.imageBase64,
        mimeType: payload.photo.mimeType,
        fileName: payload.photo.fileName,
        previewUrl: `data:${payload.photo.mimeType || "image/jpeg"};base64,${payload.photo.imageBase64}`,
        taskId: task.taskId,
        operationId: task.operationId,
      });

      if (!nextDrafts[draftKey]) {
        nextDrafts[draftKey] = {
          photoFiles: [],
          photoNames: [],
        };
      }

      nextDrafts[draftKey].photoFiles.push(localPhoto);
      nextDrafts[draftKey].photoNames.push(localPhoto.fileName || localPhoto.name);
    });

    return nextDrafts;
  }, []);

  const refreshPendingFromQueue = useCallback(async () => {
    try {
      const queueTasks = await listAllTasks();
      const nextPending = buildPendingMapFromTasks(queueTasks);
      const queuedDrafts = mergeDraftsFromQueue(queueTasks);
      setPendingMap(nextPending);
      pendingRef.current = nextPending;
      persistPending(nextPending);
      if (Object.keys(queuedDrafts).length) {
        setDrafts((prev) => {
          const merged = { ...prev };
          Object.entries(queuedDrafts).forEach(([draftKey, draftValue]) => {
            const current = merged[draftKey] || {};
            const currentPhotos = Array.isArray(current.photoFiles) ? current.photoFiles : [];
            const existingIds = new Set(currentPhotos.map((item) => item?.localId || item?.fileId).filter(Boolean));
            const incomingPhotos = (draftValue.photoFiles || []).filter((item) => !existingIds.has(item.localId || item.fileId));
            const nextPhotos = [...currentPhotos, ...incomingPhotos];
            merged[draftKey] = {
              ...current,
              photoFiles: nextPhotos,
              photoNames: nextPhotos.map((photo) => photo.fileName || photo.name),
            };
          });
          return merged;
        });
      }
      return nextPending;
    } catch (_) {
      return {};
    }
  }, [buildPendingMapFromTasks, mergeDraftsFromQueue, persistPending]);

  const restoreLocalState = useCallback(async () => {
    try {
      let parsedDrafts = await loadPersistedState(DRAFT_STORAGE_KEY);
      if (!parsedDrafts) {
        const rawDrafts = window.localStorage.getItem(DRAFT_STORAGE_KEY);
        if (rawDrafts) {
          parsedDrafts = JSON.parse(rawDrafts);
          savePersistedState(DRAFT_STORAGE_KEY, parsedDrafts).catch(() => undefined);
        }
      }
      if (parsedDrafts) {
        setDrafts(parsedDrafts || {});
      }
    } catch (_) {}

    try {
      let parsedPending = await loadPersistedState(PENDING_STORAGE_KEY);
      if (!parsedPending) {
        const rawPending = window.localStorage.getItem(PENDING_STORAGE_KEY);
        if (rawPending) {
          parsedPending = JSON.parse(rawPending) || {};
          savePersistedState(PENDING_STORAGE_KEY, parsedPending).catch(() => undefined);
        }
      }
      const queuedPending = await refreshPendingFromQueue();
      if (!Object.keys(queuedPending).length && parsedPending) {
        setPendingMap(parsedPending);
        pendingRef.current = parsedPending;
        setItemStatusMap((prev) => {
          const next = { ...prev };
          Object.keys(parsedPending).forEach((key) => {
            next[key] = "pending";
          });
          return next;
        });
      }
    } catch (_) {}
  }, [refreshPendingFromQueue]);

  useEffect(() => {
    persistDrafts(drafts);
    draftsRef.current = drafts;
  }, [drafts, persistDrafts]);

  const runQueuedTask = useCallback((queueRef, itemKey, task) => {
    const previous = queueRef.current[itemKey] || Promise.resolve();
    const next = previous.catch(() => undefined).then(task);
    queueRef.current[itemKey] = next.finally(() => {
      if (queueRef.current[itemKey] === next) {
        delete queueRef.current[itemKey];
      }
    });
    return queueRef.current[itemKey];
  }, []);

  const runWithSaveSlot = useCallback(async (task) => {
    while (activeSaveCountRef.current >= MAX_SAVE_PARALLEL) {
      await delay(120);
    }
    activeSaveCountRef.current += 1;
    try {
      return await task();
    } finally {
      activeSaveCountRef.current = Math.max(0, activeSaveCountRef.current - 1);
    }
  }, []);

  const runWithRetry = useCallback(async (task, onRetry) => {
    let lastError = null;
    for (let attempt = 0; attempt < RETRY_DELAYS_MS.length; attempt += 1) {
      try {
        return await task(attempt);
      } catch (error) {
        lastError = error;
        if (attempt === RETRY_DELAYS_MS.length - 1) break;
        if (typeof onRetry === "function") {
          await onRetry(attempt + 1, error);
        }
        await delay(RETRY_DELAYS_MS[attempt]);
      }
    }
    throw lastError || new Error("request failed");
  }, []);

  const setItemStatuses = (keys, status) => {
    if (!keys.length) return;
    setItemStatusMap((prev) => {
      const next = { ...prev };
      keys.forEach((key) => {
        next[key] = status;
      });
      return next;
    });
  };

  const removePendingKeys = useCallback((keys) => {
    if (!keys.length) return;
    setPendingMap((prev) => {
      const next = { ...prev };
      keys.forEach((key) => {
        delete next[key];
      });
      pendingRef.current = next;
      persistPending(next);
      return next;
    });
  }, [persistPending]);

  const upsertPendingEntries = useCallback((entries) => {
    if (!entries.length) return;
    setPendingMap((prev) => {
      const next = { ...prev };
      entries.forEach((entry) => {
        const prevEntry = next[entry.key] || {};
        const merged = {
          ...prevEntry,
          ...entry,
        };

        if (entry.type === "inspection") {
          merged.?뚯넚?섎웾 = prevEntry.?뚯넚?섎웾 || 0;
          merged.援먰솚?섎웾 = prevEntry.援먰솚?섎웾 || 0;
          merged.?쇳꽣紐?= prevEntry.?쇳꽣紐?|| merged.?쇳꽣紐?|| "";
          merged.鍮꾧퀬 = prevEntry.鍮꾧퀬 || merged.鍮꾧퀬 || "";
          merged.photoItems =
            (Array.isArray(entry.photoItems) && entry.photoItems.length
              ? entry.photoItems
              : prevEntry.photoItems) || [];
        }

        if (entry.type === "return" || entry.type === "exchange") {
          merged.寃?덉닔??= prevEntry.寃?덉닔??|| merged.寃?덉닔??|| 0;
        }

        if (entry.type === "movement") {
          merged.qty = parseQty(entry.qty);
          merged.?뚯넚?섎웾 = parseQty(entry.?뚯넚?섎웾);
          merged.援먰솚?섎웾 = parseQty(entry.援먰솚?섎웾);
          merged.鍮꾧퀬 = entry.鍮꾧퀬 || prevEntry.鍮꾧퀬 || "";
          merged.photoItems = serializePhotoItems(
            [
              ...(Array.isArray(prevEntry.photoItems) ? prevEntry.photoItems : []),
              ...(Array.isArray(entry.photoItems) ? entry.photoItems : []),
            ]
          );
        }

        next[entry.key] = merged;
      });
      pendingRef.current = next;
      persistPending(next);
      return next;
    });
    setItemStatuses(
      entries.map((entry) => entry.key),
      "pending"
    );
  }, [persistPending, serializePhotoItems]);
  void upsertPendingEntries;

  const enqueueTasks = useCallback(async (tasks) => {
    const list = Array.isArray(tasks) ? tasks.filter(Boolean) : [];
    if (!list.length) return [];

    await Promise.all(
      list.map((task) =>
        upsertTask({
          retryCount: Number(task.retryCount || 0),
          status: task.status || "pending",
          createdAt: Number(task.createdAt || Date.now()),
          lastTriedAt: Number(task.lastTriedAt || 0),
          ...task,
        })
      )
    );

    await refreshPendingFromQueue();
    setItemStatuses(
      list.map((task) => task.itemKey).filter(Boolean),
      "pending"
    );
    return list;
  }, [refreshPendingFromQueue]);

  const stopScanner = useCallback(() => {
    if (scannerStatusTimerRef.current) {
      clearInterval(scannerStatusTimerRef.current);
      scannerStatusTimerRef.current = null;
    }

    try {
      scannerControlsRef.current?.stop();
    } catch (_) {}

    try {
      scannerTrackRef.current?.stop();
    } catch (_) {}

    scannerControlsRef.current = null;
    scannerTrackRef.current = null;
    setScannerReady(false);
    setTorchSupported(false);
    setTorchOn(false);
  }, []);

  const closeScanner = useCallback(() => {
    stopScanner();
    setIsScannerOpen(false);
  }, [stopScanner]);

  const focusSearchInput = () => {
    requestAnimationFrame(() => {
      searchInputRef.current?.focus();
      searchInputRef.current?.scrollIntoView({ block: "center", behavior: "smooth" });
    });
  };

  const toggleTorch = async () => {
    try {
      const track = scannerTrackRef.current;
      if (!track) return;
      const next = !torchOn;
      await track.applyConstraints({ advanced: [{ torch: next }] });
      setTorchOn(next);
    } catch (_) {
      setTorchSupported(false);
      setTorchOn(false);
    }
  };

  const startScanner = useCallback(async () => {
    try {
      setScannerError("");
      setScannerReady(false);
      setScannerStatus("燁삳?李??? 餓Β??쑵釉????됰뮸??덈뼄...");

      const reader = new BrowserMultiFormatReader();
      const devices = await BrowserCodeReader.listVideoInputDevices();
      const backCamera =
        devices.find((device) => /back|rear|environment/i.test(String(device.label || ""))) || devices[0];

      const callback = (result, err, controls) => {
        if (controls) {
          scannerControlsRef.current = controls;

          try {
            const stream = scannerVideoRef.current?.srcObject;
            const track = stream?.getVideoTracks?.()?.[0] || null;
            scannerTrackRef.current = track || scannerTrackRef.current;

            const capabilities =
              track && typeof track.getCapabilities === "function"
                ? track.getCapabilities()
                : null;

            if (capabilities && "torch" in capabilities) {
              setTorchSupported(true);
            }
          } catch (_) {}
        }

        if (result) {
          const scanned = String(
            typeof result.getText === "function" ? result.getText() : result.text || result
          )
            .replace(/\s+/g, "")
            .trim();

          if (scanned) {
            if (typeof navigator !== "undefined" && typeof navigator.vibrate === "function") {
              navigator.vibrate(100);
            }
            setSearch(scanned);
            closeScanner();
          }
          return;
        }

        if (!err || err.name === "NotFoundException") {
          setScannerReady((prev) => prev || true);
          return;
        }

        return;
      };

      if (backCamera?.deviceId) {
        scannerControlsRef.current = await reader.decodeFromVideoDevice(
          backCamera.deviceId,
          scannerVideoRef.current,
          callback
        );
      } else {
        scannerControlsRef.current = await reader.decodeFromConstraints(
          {
            video: {
              facingMode: { ideal: "environment" },
              width: { ideal: 1280 },
              height: { ideal: 720 },
            },
          },
          scannerVideoRef.current,
          callback
        );
      }

      scannerStatusTimerRef.current = setInterval(() => {
        setScannerStatus((prev) =>
          prev === "諛붿퐫???몄떇 以?.."
            ? "諛붿퐫?쒕? ?붾㈃ 以묒븰??留욎떠 二쇱꽭??"
            : "諛붿퐫???몄떇 以?.."
        );
      }, 2200);

      setScannerStatus("諛붿퐫???몄떇 以?..");
    } catch (err) {
      setScannerError(err.message || "移대찓?쇰? ?쒖옉?????놁뒿?덈떎.");
      setScannerStatus("移대찓?쇰? ?ъ슜?????놁뒿?덈떎.");
      stopScanner();
    }
  }, [closeScanner, stopScanner]);
  const handleCsvUpload = async (e) => {
    const file = e.target.files?.[0];
    if (!file) return;
  
    try {
      const totalStartedAt = performance.now();
      setUploadingCsv(true);
      setError("");
      setMessage("");
  
      const parseStartedAt = performance.now();
      const parsedRows = await parseCsvFileInWorker(file);
      const parseMs = performance.now() - parseStartedAt;

      const normalizeStartedAt = performance.now();
      const normalized = buildNormalizedRows(parsedRows);
      const mergedRows = mergeRowsWithReservation(normalized, reservationRows);
      const jobKey = computeJobKey(normalized);
      const normalizeMs = performance.now() - normalizeStartedAt;

      const nextJob = {
        job_key: jobKey,
        rows: normalized,
        source_file_name: file.name,
        source_file_modified: new Date(file.lastModified).toISOString(),
      };

      setRows(mergedRows);
      setCurrentJob(nextJob);
      setCurrentFileName(file.name);
      setCurrentFileModifiedAt(nextJob.source_file_modified);
      setMessage(`CSV ?뚯떛 ?꾨즺 (${normalized.length.toLocaleString("ko-KR")}嫄? ?쒕쾭 罹먯떆 ???以?..)`);

      const cacheStartedAt = performance.now();
      const response = await fetch(SCRIPT_URL, {
        method: "POST",
        headers: { "Content-Type": "text/plain;charset=utf-8" },
        body: serializeRequestBody({
          action: "cacheCsv",
          payload: {
            job_key: jobKey,
            source_file_name: file.name,
            source_file_modified: new Date(file.lastModified).toISOString(),
            parsed_rows_base64: normalized.map((row) => encodeBase64Utf8(JSON.stringify(row))),
          },
        }),
      });

      const result = await response.json();
      const cacheMs = performance.now() - cacheStartedAt;
      if (!response.ok || result.ok === false) {
          throw new Error(result.message || "CSV 罹먯떆 ????ㅽ뙣");
      }

      const resolvedJob = result.job && Array.isArray(result.job.rows)
        ? { ...result.job, rows: result.job.rows }
        : nextJob;

      setRows(mergedRows);
      setCurrentJob({ ...resolvedJob, rows: normalized });
      setCurrentFileName(file.name);
      setCurrentFileModifiedAt(new Date(file.lastModified).toISOString());
      setDashboardSummary(result.summary || {});

      recordPerformance(
        "csv_upload",
        file.name,
        {
          parseMs,
          normalizeMs,
          cacheMs,
          totalMs: performance.now() - totalStartedAt,
          rowCount: normalized.length,
        },
        {
          rowCount: normalized.length,
          serverMs: result?.perf?.serverMs || 0,
        }
      );

      setMessage("CSV ?낅줈???꾨즺");
    } catch (err) {
      setError(err.message || "CSV 泥섎━ ?ㅽ뙣");
    } finally {
      setUploadingCsv(false);
      if (e.target) {
        e.target.value = "";
      }
    }
  };
  // eslint-disable-next-line react-hooks/exhaustive-deps
  useEffect(() => {
    if (!isScannerOpen) {
      stopScanner();
      return undefined;
    }

    startScanner();
    return () => stopScanner();
  }, [isScannerOpen, startScanner, stopScanner]);

  const loadBootstrap = useCallback(async () => {
    if (!SCRIPT_URL.trim()) {
      setBootLoading(false);
      setError("REACT_APP_GOOGLE_SCRIPT_URL ?섍꼍蹂寃쎌씠 ?꾩슂?⑸땲??");
      return;
    }

    try {
      setBootLoading(true);
      setError("");

      const response = await fetch(`${SCRIPT_URL}?action=bootstrap`);
      const result = await response.json();

      if (!response.ok || result.ok === false) {
        throw new Error(result.message || "珥덇린 ?곗씠?곕? 遺덈윭?ㅼ? 紐삵뻽?듬땲??");
      }

      const data = result.data || {};
      const config = data.config || {};
      const job = data.current_job || null;
      setWorksheetUrl(data.worksheet_url || "");
      const normalizedReservationRows = buildReservationRows(config.reservation_rows || []);

      const nextExcludedProductCodes = new Set();
      const nextExcludedPairKeys = new Set();

      (config.exclude_rows || []).forEach((row) => {
        const productCode = normalizeProductCode(
          getValue(row, ["?곹뭹肄붾뱶", "?곹뭹 肄붾뱶", "肄붾뱶", "諛붿퐫??])
        );
        const partner = String(getValue(row, ["?묐젰??, "?묐젰?щ챸"]) || "").trim();
        const useFlag = getValue(row, ["?ъ슜?щ?"]);

        if (!isTruthyUsage(useFlag)) return;
        if (!productCode) return;

        if (partner) {
          nextExcludedPairKeys.add(`${productCode}||${partner}`);
        } else {
          nextExcludedProductCodes.add(productCode);
        }
      });

      const nextEventMap = {};
      (config.event_rows || []).forEach((row) => {
        const productCode = normalizeProductCode(
          getValue(row, ["?곹뭹肄붾뱶", "?곹뭹 肄붾뱶", "肄붾뱶", "諛붿퐫??])
        );
        const eventName = String(getValue(row, ["?됱궗紐?]) || "").trim();
        const useFlag = getValue(row, ["?ъ슜?щ?"]);

        if (!productCode) return;
        if (isExplicitFalseUsage(useFlag)) return;

        nextEventMap[productCode] = {
          ?됱궗?щ?: "?됱궗",
          ?됱궗紐? eventName,
        };
      });

      setExcludedProductCodes(nextExcludedProductCodes);
      setExcludedPairKeys(nextExcludedPairKeys);
      setEventMap(nextEventMap);
      setReservationRows(normalizedReservationRows);
      setCurrentJob(job);
      setRows(Array.isArray(job?.rows) ? mergeJobRowsWithReservation(job.rows, normalizedReservationRows) : []);
      setCurrentFileName(job?.source_file_name || "");
      setCurrentFileModifiedAt(job?.source_file_modified || "");
      setDashboardSummary(data.summary || {});
      setHappycallAnalytics(data.happycall || {});
      setProductImageMap(buildProductImageMapFromRows(data.product_images));
      setMessage(job ? "理쒓렐 ?묒뾽??遺덈윭?붿뒿?덈떎." : "CSV瑜??낅줈?쒗빐 二쇱꽭??");
    } catch (err) {
      setError(err.message || "珥덇린 ?곗씠?곕? 遺덈윭?ㅼ? 紐삵뻽?듬땲??");
    } finally {
      setBootLoading(false);
    }
  }, []);

  const fetchHistoryRowsData = useCallback(async () => {
    const response = await fetch(`${SCRIPT_URL}?action=getRecords`);
    const result = await response.json();

    if (!response.ok || result.ok === false) {
      throw new Error(result.message || "?댁뿭 遺덈윭?ㅺ린 ?ㅽ뙣");
    }

    return (Array.isArray(result.records) ? result.records : []).sort((a, b) =>
      String(b.?묒꽦?쇱떆 || "").localeCompare(String(a.?묒꽦?쇱떆 || ""), "ko")
    );
  }, []);

  const fetchInspectionRowsData = useCallback(async () => {
    const response = await fetch(`${SCRIPT_URL}?action=getInspectionRows`);
    const result = await response.json();

    if (!response.ok || result.ok === false) {
      throw new Error(result.message || "寃???곗씠??遺덈윭?ㅺ린 ?ㅽ뙣");
    }

    return Array.isArray(result.rows) ? result.rows : [];
  }, []);

  const loadHistoryRows = useCallback(async () => {
    try {
      setHistoryLoading(true);
      setError("");
      const nextRows = await fetchHistoryRowsData();
      setHistoryRows(nextRows);
      return nextRows;
    } catch (err) {
      setError(err.message || "??곷열???븍뜄???? 筌륁궢六??щ빍??");
      setHistoryRows([]);
      return [];
    } finally {
      setHistoryLoading(false);
    }
  }, [fetchHistoryRowsData]);

  const loadInspectionRows = useCallback(async () => {
    try {
      const nextRows = await fetchInspectionRowsData();
      setInspectionRows(nextRows);
      return nextRows;
    } catch (err) {
      setError(err.message || "野꺜???怨쀬뵠?怨? ?븍뜄???? 筌륁궢六??щ빍??");
      setInspectionRows([]);
      return [];
    }
  }, [fetchInspectionRowsData]);

  const loadEditLocks = useCallback(async () => {
    try {
      const response = await fetch(`${SCRIPT_URL}?action=getEditLocks`);
      const result = await response.json();
      if (!response.ok || result.ok === false) {
        throw new Error(result.message || "?몄쭛 ?좉툑 議고쉶 ?ㅽ뙣");
      }
      setLockMap(result.locks || {});
      return result.locks || {};
    } catch (err) {
      return {};
    }
  }, []);

  useEffect(() => {
    loadBootstrap();
    loadHistoryRows();
    loadInspectionRows();
    loadEditLocks();
  }, [loadBootstrap, loadEditLocks, loadHistoryRows, loadInspectionRows]);

  useEffect(() => {
    restoreLocalState();
  }, [restoreLocalState]);

  useEffect(() => {
    const timer = window.setInterval(() => {
      loadHistoryRows();
      loadInspectionRows();
      loadEditLocks();
    }, 30000);
    return () => window.clearInterval(timer);
  }, [loadEditLocks, loadHistoryRows, loadInspectionRows]);

  useEffect(() => {
    const itemKey = expandedProductCode || recordDetailKey;
    if (!itemKey) {
      activeLockKeyRef.current = "";
      return undefined;
    }

    let cancelled = false;
    const syncLock = async (action) => {
      try {
        const response = await fetch(SCRIPT_URL, {
          method: "POST",
          headers: { "Content-Type": "text/plain;charset=utf-8" },
          body: serializeRequestBody({
            action,
            payload: {
              itemKey,
              editorId: editorProfile.editorId,
              editorName: editorProfile.editorName,
            },
          }),
        });
        const result = await response.json();
        if (!cancelled) {
          if (result.lock) {
            setLockMap((prev) => ({ ...prev, [itemKey]: result.lock }));
          }
          if (result.conflict) {
            setItemStatusMap((prev) => ({ ...prev, [itemKey]: "conflict" }));
          }
        }
      } catch (_) {}
    };

    activeLockKeyRef.current = itemKey;
    syncLock("acquireEditLock");
    const timer = window.setInterval(() => {
      syncLock("heartbeatEditLock");
    }, 30000);

    return () => {
      cancelled = true;
      window.clearInterval(timer);
      fetch(SCRIPT_URL, {
        method: "POST",
        headers: { "Content-Type": "text/plain;charset=utf-8" },
        body: serializeRequestBody({
          action: "releaseEditLock",
          payload: {
            itemKey,
            editorId: editorProfile.editorId,
          },
        }),
      }).catch(() => undefined);
    };
  }, [editorProfile.editorId, editorProfile.editorName, expandedProductCode, recordDetailKey]);

  const filteredRows = useMemo(() => {
    return rows.filter((row) => {
      const code = normalizeProductCode(row.__productCode);
      const partner = String(row.__partner || "").trim();

      if (!code) return false;
      if (excludedProductCodes.has(code)) return false;
      if (excludedPairKeys.has(`${code}||${partner}`)) return false;

      return true;
    });
  }, [rows, excludedProductCodes, excludedPairKeys]);

  const groupedPartners = useMemo(() => {
    const keyword = normalizeText(search);
    const map = new Map();

    filteredRows.forEach((row) => {
      const productCode = row.__productCode;
      const productName = row.__productName || "?곹뭹紐??놁쓬";
      const partner = row.__partner || "?묐젰???놁쓬";
      const center = row.__center || "?쇳꽣 ?놁쓬";
      const qty = row.__qty || 0;

      const matched =
        !keyword ||
        normalizeText(productName).includes(keyword) ||
        normalizeText(partner).includes(keyword) ||
        String(productCode || "").includes(search.trim());

      if (!matched) return;

      if (!map.has(partner)) {
        map.set(partner, []);
      }

      const partnerProducts = map.get(partner);
      let product = partnerProducts.find((item) => item.productCode === productCode);

      if (!product) {
        product = {
          productCode,
          productName,
          partner,
          totalQty: 0,
          centers: [],
          eventInfo: eventMap[productCode] || null,
          happycallMetrics: getHappycallProductMetrics(happycallAnalytics, {
            productCode,
            productName,
            partner,
          }),
        };
        partnerProducts.push(product);
      }

      product.totalQty += qty;

      let centerInfo = product.centers.find((item) => item.center === center);
      if (!centerInfo) {
        centerInfo = {
          center,
          totalQty: 0,
          rows: [],
        };
        product.centers.push(centerInfo);
      }

      centerInfo.totalQty += qty;
      centerInfo.rows.push(row);
    });

    const allProducts = Array.from(map.values()).flat();
    const rankMaps = {
      "1d": {},
      "7d": {},
      "30d": {},
    };

    Object.keys(rankMaps).forEach((periodKey) => {
      allProducts
        .filter((product) => parseQty(product.happycallMetrics?.[periodKey]?.count) > 0)
        .sort((a, b) => {
          const countDiff =
            parseQty(b.happycallMetrics?.[periodKey]?.count) - parseQty(a.happycallMetrics?.[periodKey]?.count);
          if (countDiff !== 0) return countDiff;
          return String(a.productName || "").localeCompare(String(b.productName || ""), "ko");
        })
        .slice(0, 5)
        .forEach((product, index) => {
          rankMaps[periodKey][`${product.partner}||${product.productCode}`] = {
            rank: index + 1,
            count: parseQty(product.happycallMetrics?.[periodKey]?.count),
            share: Number(product.happycallMetrics?.[periodKey]?.share || 0),
          };
        });
    });

    const visibleHappycallRankMap = buildVisibleHappycallRanks(happycallAnalytics);

    return Array.from(map.entries())
      .sort((a, b) => a[0].localeCompare(b[0], "ko"))
      .map(([partner, products]) => ({
        partner,
        products: products.map((product) => ({
          ...product,
          imageSrc: getProductImageSrc(product, productImageMap),
          happycallStats: {
            "1d": visibleHappycallRankMap[`${product.partner}||${product.productCode}`]?.["1d"] || null,
            "7d": visibleHappycallRankMap[`${product.partner}||${product.productCode}`]?.["7d"] || null,
            "30d": visibleHappycallRankMap[`${product.partner}||${product.productCode}`]?.["30d"] || null,
          },
          centers: product.centers.sort((a, b) => (b.totalQty || 0) - (a.totalQty || 0)),
        })),
      }));
  }, [filteredRows, search, eventMap, happycallAnalytics, productImageMap]);

  const historyCountMap = useMemo(() => {
    const map = {};

    (historyRows || []).forEach((record) => {
      const key = `${record.?묐젰?щ챸 || ""}||${record.?곹뭹肄붾뱶 || ""}`;
      if (!map[key]) {
        map[key] = { returnCount: 0, exchangeCount: 0 };
      }

      if (parseQty(record.?뚯넚?섎웾) > 0) {
        map[key].returnCount += 1;
      }

      if (parseQty(record.援먰솚?섎웾) > 0) {
        map[key].exchangeCount += 1;
      }
    });

    return map;
  }, [historyRows]);

  const inspectionSavedMap = useMemo(() => {
    const map = {};

    (inspectionRows || []).forEach((row) => {
      const key = makeEntityKey(
        row.?묒뾽湲곗??쇰삉?봀SV?앸퀎媛?
        row.?곹뭹肄붾뱶,
        row.?묐젰?щ챸
      );
      map[key] = {
        inspectionQty: parseQty(row.寃?덉닔??,
        returnQty: parseQty(row.?뚯넚?섎웾),
        exchangeQty: parseQty(row.援먰솚?섎웾),
        updatedAt: String(row.?섏젙?쇱떆 || "").trim(),
        updatedBy: String(row.?섏젙??|| "").trim(),
        version: Number(row.踰꾩쟾 || 0),
      };
    });

    return map;
  }, [inspectionRows]);

  const movementSavedMap = useMemo(() => {
    const map = {};

    (historyRows || []).forEach((row) => {
      const typeName = String(row.泥섎━?좏삎 || "").trim();
      const key = makeMovementPendingKey(
        typeName === "援먰솚" ? "EXCHANGE" : typeName === "?뚯넚" ? "RETURN" : typeName,
        row.?묒뾽湲곗??쇰삉?봀SV?앸퀎媛?
        row.?곹뭹肄붾뱶,
        row.?묐젰?щ챸,
        row.?쇳꽣紐?
      );

      if (!map[key]) {
        map[key] = {
          returnQty: 0,
          exchangeQty: 0,
          updatedAt: "",
          updatedBy: "",
          version: 0,
        };
      }

      map[key].returnQty += parseQty(row.?뚯넚?섎웾);
      map[key].exchangeQty += parseQty(row.援먰솚?섎웾);
      map[key].updatedAt = String(row.?섏젙?쇱떆 || map[key].updatedAt || "").trim();
      map[key].updatedBy = String(row.?섏젙??|| map[key].updatedBy || "").trim();
      map[key].version = Number(row.踰꾩쟾 || map[key].version || 0);
    });

    return map;
  }, [historyRows]);

  const productLookupMap = useMemo(() => {
    const map = new Map();
    groupedPartners.forEach((group) => {
      group.products.forEach((product) => {
        map.set(makeHistoryProductKey(product.partner, product.productCode), product);
      });
    });
    return map;
  }, [groupedPartners]);

  const filteredHistoryRows = useMemo(() => {
    const keyword = normalizeText(search);
    if (!keyword) return historyRows || [];
    return (historyRows || []).filter((row) => {
      const productName = String(row["?곹뭹紐?] || row.productName || row["?怨밸?筌?"] || "").trim();
      const partnerName = String(row["?묐젰?щ챸"] || row.partnerName || row["?臾먯젾??梨?] || "").trim();
      const productCode = normalizeProductCode(row["?곹뭹肄붾뱶"] || row.productCode || row["?怨밸??꾨뗀諭?] || "");
      return (
        normalizeText(productName).includes(keyword) ||
        normalizeText(partnerName).includes(keyword) ||
        productCode.includes(search.trim())
      );
    });
  }, [historyRows, search]);

  const filteredInspectionRows = useMemo(() => {
    const keyword = normalizeText(search);
    if (!keyword) return inspectionRows || [];
    return (inspectionRows || []).filter((row) => {
      const productName = String(row["?곹뭹紐?] || row.productName || row["?怨밸?筌?"] || "").trim();
      const partnerName = String(row["?묐젰?щ챸"] || row.partnerName || row["?臾먯젾??梨?] || "").trim();
      const productCode = normalizeProductCode(row["?곹뭹肄붾뱶"] || row.productCode || row["?怨밸??꾨뗀諭?] || "");
      return (
        normalizeText(productName).includes(keyword) ||
        normalizeText(partnerName).includes(keyword) ||
        productCode.includes(search.trim())
      );
    });
  }, [inspectionRows, search]);

  const recordItems = useMemo(() => {
    const map = new Map();

    (filteredInspectionRows || []).forEach((row) => {
      const partnerName = String(row["?묐젰?щ챸"] || row.partnerName || row["?臾먯젾??梨?] || "").trim();
      const productCode = normalizeProductCode(row["?곹뭹肄붾뱶"] || row.productCode || row["?怨밸??꾨뗀諭?] || "");
      const productName = String(row["?곹뭹紐?] || row.productName || row["?怨밸?筌?"] || "").trim();
      const key = makeHistoryProductKey(partnerName, productCode);
      if (!key) return;

      const existing = map.get(key) || {
        key,
        partnerName,
        productCode,
        productName,
        inspectionQty: 0,
        returnQty: 0,
        exchangeQty: 0,
        latestTime: "",
      };

      existing.inspectionQty = parseQty(row["寃?덉닔??] || row.inspectionQty || row["野꺜??됰땾??"] || 0);
      const updatedAt = String(row["?섏젙?쇱떆"] || row.updatedAt || row["??륁젟??깅뻻"] || row["?묒꽦?쇱떆"] || "").trim();
      if (updatedAt && updatedAt > existing.latestTime) existing.latestTime = updatedAt;
      if (!existing.productName) existing.productName = productName;
      map.set(key, existing);
    });

    (filteredHistoryRows || []).forEach((row) => {
      const partnerName = String(row["?묐젰?щ챸"] || row.partnerName || row["?臾먯젾??梨?] || "").trim();
      const productCode = normalizeProductCode(row["?곹뭹肄붾뱶"] || row.productCode || row["?怨밸??꾨뗀諭?] || "");
      const productName = String(row["?곹뭹紐?] || row.productName || row["?怨밸?筌?"] || "").trim();
      const key = makeHistoryProductKey(partnerName, productCode);
      if (!key) return;

      const existing = map.get(key) || {
        key,
        partnerName,
        productCode,
        productName,
        inspectionQty: 0,
        returnQty: 0,
        exchangeQty: 0,
        latestTime: "",
      };

      existing.returnQty += parseQty(row["?뚯넚?섎웾"] || row.returnQty || row["???꽊??롮쎗"] || 0);
      existing.exchangeQty += parseQty(row["援먰솚?섎웾"] || row.exchangeQty || row["?대????롮쎗"] || 0);
      const updatedAt = String(row["?섏젙?쇱떆"] || row.updatedAt || row["??륁젟??깅뻻"] || row["?묒꽦?쇱떆"] || "").trim();
      if (updatedAt && updatedAt > existing.latestTime) existing.latestTime = updatedAt;
      if (!existing.productName) existing.productName = productName;
      map.set(key, existing);
    });

    return Array.from(map.values()).sort((a, b) => {
      const partnerDiff = String(a.partnerName || "").localeCompare(String(b.partnerName || ""), "ko");
      if (partnerDiff !== 0) return partnerDiff;
      return String(a.productName || "").localeCompare(String(b.productName || ""), "ko");
    });
  }, [filteredHistoryRows, filteredInspectionRows]);

  const selectedHappycallPeriodMeta = {
    "1d": { title: "?쇰퀎 ?댄뵾肄?TOP 5", subtitle: "?꾩씪 ?묒닔 ?댄뵾肄?湲곗?" },
    "7d": { title: "二쇰퀎 ?댄뵾肄?TOP 5", subtitle: "留덉?留??쇱옄 ?ы븿 7??湲곗?" },
    "30d": { title: "?붾퀎 ?댄뵾肄?TOP 5", subtitle: "留덉?留??쇱옄 ?ы븿 30??湲곗?" },
  }[selectedHappycallPeriod] || { title: "?쇰퀎 ?댄뵾肄?TOP 5", subtitle: "?꾩씪 ?묒닔 ?댄뵾肄?湲곗?" };

  const selectedHappycallTopList = useMemo(
    () =>
      (happycallAnalytics?.periods?.[selectedHappycallPeriod]?.topProducts || [])
        .filter(isClassifiedHappycallProduct)
        .slice(0, 5)
        .map((item, index) => ({
          rank: index + 1,
          productName: item?.productName || "-",
          count: parseQty(item?.count || 0),
          share: Number(item?.share || 0),
          partnerName: item?.partnerName || "",
          productCode: item?.productCode || "",
          imageSrc: getProductImageSrc({
            productName: item?.productName || "",
            partner: item?.partnerName || "",
            productCode: item?.productCode || "",
          }, productImageMap),
        })),
    [happycallAnalytics, productImageMap, selectedHappycallPeriod]
  );

  const happycallHeroCard = selectedHappycallTopList[0] || null;
  const happycallMiniCards = selectedHappycallTopList.slice(1, 5);
  const totalVisibleProducts = groupedPartners.reduce((sum, item) => sum + item.products.length, 0);
  const analyticsKpis = useMemo(() => {
    const totalInboundQty = filteredRows.reduce((sum, row) => sum + parseQty(row.__qty || 0), 0);
    const totalInboundAmount = filteredRows.reduce(
      (sum, row) => sum + parseQty(row.__qty || 0) * parseQty(row.__incomingCost || 0),
      0
    );
    const inspectedQty = (inspectionRows || []).reduce((sum, row) => sum + parseQty(row.寃?덉닔??, 0);
    const inspectedSku = new Set(
      (inspectionRows || [])
        .filter((row) => parseQty(row.寃?덉닔?? > 0)
        .map((row) => `${row.?묐젰?щ챸 || ""}||${row.?곹뭹肄붾뱶 || ""}`)
    ).size;
    const inspectionRate = totalInboundQty > 0 ? inspectedQty / totalInboundQty : 0;
    const skuCoverage = filteredRows.length > 0 ? inspectedSku / filteredRows.length : 0;

    return [
      { label: "珥??낃퀬湲덉븸", value: formatDashboardValue("珥??낃퀬湲덉븸", dashboardSummary?.totalInboundAmount ?? totalInboundAmount) },
      { label: "珥??낃퀬?섎웾", value: formatDashboardValue("珥??낃퀬?섎웾", dashboardSummary?.totalInboundQty ?? totalInboundQty) },
      { label: "寃???낃퀬湲덉븸", value: formatDashboardValue("寃???낃퀬湲덉븸", dashboardSummary?.inspectionInboundAmount ?? 0) },
      { label: "寃?늆KU", value: formatDashboardValue("寃?늆KU", dashboardSummary?.inspectionSku ?? inspectedSku) },
      { label: "寃???섎웾", value: formatDashboardValue("寃???섎웾", dashboardSummary?.inspectionQty ?? inspectedQty) },
      { label: "寃?덈쪧", value: formatDashboardValue("寃?덈쪧", dashboardSummary?.inspectionRate ?? inspectionRate) },
      { label: "??寃?덈쪧", value: formatDashboardValue("??寃?덈쪧", dashboardSummary?.realInspectionRate ?? inspectionRate) },
      { label: "SKU 而ㅻ쾭由ъ?", value: formatDashboardValue("SKU 而ㅻ쾭由ъ?", dashboardSummary?.skuCoverage ?? skuCoverage) },
    ];
  }, [dashboardSummary, filteredRows, inspectionRows]);
  const imageRegistryProducts = useMemo(() => {
    const keyword = normalizeText(imageRegisterSearch);
    const flatList = groupedPartners.flatMap((group) =>
      group.products.map((product) => {
        const imageKey = makeProductImageMapKey({
          productCode: product.productCode,
          partner: group.partner,
          productName: product.productName,
        });
        const customImageSrc = imageKey ? productImageMap[imageKey] || "" : "";

        return {
          partner: group.partner,
          productCode: product.productCode,
          productName: product.productName,
          imageSrc: product.imageSrc || getDefaultProductImageSrc(product),
          customImageSrc,
          hasCustomImage: !!customImageSrc,
          hasVisibleImage: !!(product.imageSrc || getDefaultProductImageSrc(product)),
          totalQty: product.totalQty || 0,
          imageKey,
        };
      })
    );

    return flatList
      .filter((item) => {
        if (!keyword) return true;
        return (
          normalizeText(item.productName).includes(keyword) ||
          normalizeText(item.partner).includes(keyword) ||
          String(item.productCode || "").includes(imageRegisterSearch.trim())
        );
      })
      .sort((a, b) => {
        const partnerDiff = String(a.partner || "").localeCompare(String(b.partner || ""), "ko");
        if (partnerDiff !== 0) return partnerDiff;
        return String(a.productName || "").localeCompare(String(b.productName || ""), "ko");
      });
  }, [groupedPartners, imageRegisterSearch, productImageMap]);

  const postSheetAction = useCallback(async (action, payload) => {
    const response = await fetch(SCRIPT_URL, {
      method: "POST",
      headers: { "Content-Type": "text/plain;charset=utf-8" },
      body: serializeRequestBody({ action, ...payload }),
    });
    const result = await response.json();
    if (!response.ok || result.ok === false) {
      throw new Error(result.message || "?붿껌 泥섎━???ㅽ뙣?덉뒿?덈떎.");
    }
    return result;
  }, []);

  const buildRecordDetailDraft = useCallback((item) => {
    if (!item) return null;

    const lookupProduct = productLookupMap.get(item.key) || null;
    const partnerName = item.partnerName || lookupProduct?.partner || "";
    const productCode = item.productCode || lookupProduct?.productCode || "";
    const inspectionRow =
      filteredInspectionRows.find(
        (row) =>
          makeHistoryProductKey(row["?묐젰?щ챸"] || row.partnerName || row["?臾먯젾??梨?] || "", row["?곹뭹肄붾뱶"] || row.productCode || row["?怨밸??꾨뗀諭?] || "") === item.key
      ) || null;
    const movementRows = filteredHistoryRows.filter(
      (row) =>
        makeHistoryProductKey(row["?묐젰?щ챸"] || row.partnerName || row["?臾먯젾??梨?] || "", row["?곹뭹肄붾뱶"] || row.productCode || row["?怨밸??꾨뗀諭?] || "") === item.key
    );

    const centerOptions = Array.from(
      new Set(
        [
          ...(lookupProduct?.centers || []).map((center) => center.center),
          ...movementRows.map((row) => String(row["?쇳꽣紐?] || row.centerName || row["??녠숲筌?"] || "").trim()).filter(Boolean),
        ].filter(Boolean)
      )
    );

    const selectedCenter =
      movementRows[0]?.["?쇳꽣紐?] ||
      movementRows[0]?.centerName ||
      movementRows[0]?.["??녠숲筌?"] ||
      lookupProduct?.centers?.[0]?.center ||
      centerOptions[0] ||
      "";

    const selectedCenterRows = movementRows.filter(
      (row) => String(row["?쇳꽣紐?] || row.centerName || row["??녠숲筌?"] || "").trim() === String(selectedCenter || "").trim()
    );
    const returnRow =
      selectedCenterRows.find((row) => String(row["泥섎━?좏삎"] || row.typeName || row["筌ｌ꼶??醫륁굨"] || "").trim() === "?뚯넚") || null;
    const exchangeRow =
      selectedCenterRows.find((row) => String(row["泥섎━?좏삎"] || row.typeName || row["筌ｌ꼶??醫륁굨"] || "").trim() === "援먰솚") || null;

    const inspectionSources = splitPhotoSourceText(inspectionRow?.["?ъ쭊留곹겕紐⑸줉"] || inspectionRow?.["?ъ쭊?뚯씪ID紐⑸줉"] || "");
    const returnSources = splitPhotoSourceText(returnRow?.["?ъ쭊留곹겕紐⑸줉"] || returnRow?.["?ъ쭊?뚯씪ID紐⑸줉"] || "");
    const exchangeSources = splitPhotoSourceText(exchangeRow?.["?ъ쭊留곹겕紐⑸줉"] || exchangeRow?.["?ъ쭊?뚯씪ID紐⑸줉"] || "");
    const brixMinText = formatBrixValue(inspectionRow?.brixMin ?? inspectionRow?.["BRIX理쒖?"] ?? "");
    const brixMaxText = formatBrixValue(inspectionRow?.brixMax ?? inspectionRow?.["BRIX理쒓퀬"] ?? "");
    const brixMin = parseBrixInput(brixMinText);
    const brixMax = parseBrixInput(brixMaxText);

    return {
      key: item.key,
      partnerName,
      productCode,
      productName: item.productName || lookupProduct?.productName || "",
      product: lookupProduct,
      selectedCenter,
      centerOptions,
      inspectionQty: String(parseQty(inspectionRow?.["寃?덉닔??] || inspectionRow?.inspectionQty || item.inspectionQty || 0)),
      returnQty: String(parseQty(returnRow?.["?뚯넚?섎웾"] || returnRow?.returnQty || 0)),
      exchangeQty: String(parseQty(exchangeRow?.["援먰솚?섎웾"] || exchangeRow?.exchangeQty || 0)),
      memo: String(returnRow?.["鍮꾧퀬"] || exchangeRow?.["鍮꾧퀬"] || inspectionRow?.["鍮꾧퀬"] || inspectionRow?.memo || ""),
      brixMin: brixMinText,
      brixMax: brixMaxText,
      brixAvg: computeBrixAvg(brixMin, brixMax),
      weightNote: String(inspectionRow?.["以묐웾硫붾え"] || inspectionRow?.weightNote || ""),
      photoGroups: {
        inspection: toPhotoItemsFromUrls(inspectionSources.map((url) => ({ driveUrl: url })), "inspection"),
        return: toPhotoItemsFromUrls(returnSources.map((url) => ({ driveUrl: url })), "return"),
        exchange: toPhotoItemsFromUrls(exchangeSources.map((url) => ({ driveUrl: url })), "exchange"),
        sugar: [],
        weight: [],
      },
      existingRows: {
        inspection: inspectionRow,
        movements: movementRows,
      },
    };
  }, [filteredHistoryRows, filteredInspectionRows, productLookupMap]);

  const openRecordDetail = useCallback((itemKey) => {
    const item = recordItems.find((entry) => entry.key === itemKey);
    if (!item) return;
    setRecordDetailKey(itemKey);
    setRecordDetailDraft(buildRecordDetailDraft(item));
  }, [buildRecordDetailDraft, recordItems]);

  const closeRecordDetail = useCallback(() => {
    setRecordDetailKey("");
    setRecordDetailDraft(null);
  }, []);

  const updateRecordDetailDraft = useCallback((patch) => {
    setRecordDetailDraft((prev) => {
      if (!prev) return prev;
      const next = { ...prev, ...patch };
      const min = parseBrixInput(next.brixMin);
      const max = parseBrixInput(next.brixMax);
      next.brixAvg = computeBrixAvg(min, max);
      return next;
    });
  }, []);

  const rebuildRecordDetailForCenter = useCallback((prev, nextCenter) => {
    if (!prev) return prev;
    const movements = Array.isArray(prev.existingRows?.movements) ? prev.existingRows.movements : [];
    const selectedRows = movements.filter(
      (row) => String(row["?쇳꽣紐?] || row.centerName || row["??녠숲筌?"] || "").trim() === String(nextCenter || "").trim()
    );
    const returnRow =
      selectedRows.find((row) => String(row["泥섎━?좏삎"] || row["筌ｌ꼶??醫륁굨"] || "").trim() === "?뚯넚") || null;
    const exchangeRow =
      selectedRows.find((row) => String(row["泥섎━?좏삎"] || row["筌ｌ꼶??醫륁굨"] || "").trim() === "援먰솚") || null;

    return {
      ...prev,
      selectedCenter: nextCenter,
      returnQty: String(parseQty(returnRow?.["?뚯넚?섎웾"] || returnRow?.returnQty || 0)),
      exchangeQty: String(parseQty(exchangeRow?.["援먰솚?섎웾"] || exchangeRow?.exchangeQty || 0)),
      memo: String(returnRow?.["鍮꾧퀬"] || exchangeRow?.["鍮꾧퀬"] || prev.memo || ""),
      photoGroups: {
        ...prev.photoGroups,
        return: toPhotoItemsFromUrls(
          splitPhotoSourceText(returnRow?.["?ъ쭊留곹겕紐⑸줉"] || returnRow?.["?ъ쭊?뚯씪ID紐⑸줉"] || "").map((url) => ({ driveUrl: url })),
          "return"
        ),
        exchange: toPhotoItemsFromUrls(
          splitPhotoSourceText(exchangeRow?.["?ъ쭊留곹겕紐⑸줉"] || exchangeRow?.["?ъ쭊?뚯씪ID紐⑸줉"] || "").map((url) => ({ driveUrl: url })),
          "exchange"
        ),
      },
    };
  }, []);

  const handleRecordPhotoSelect = useCallback((photoType, fileList) => {
    const files = Array.from(fileList || []);
    if (!files.length) return;

    setRecordDetailDraft((prev) => {
      if (!prev) return prev;
      const nextItems = files.map((file, index) => ({
        id: `${photoType}-${Date.now()}-${index}`,
        file,
        fileName: file.name,
        previewUrl: URL.createObjectURL(file),
        photoType,
        persisted: false,
      }));
      return {
        ...prev,
        photoGroups: {
          ...prev.photoGroups,
          [photoType]: [...(prev.photoGroups?.[photoType] || []), ...nextItems],
        },
      };
    });
  }, []);

  const removeRecordPhoto = useCallback((photoType, itemId) => {
    setRecordDetailDraft((prev) => {
      if (!prev) return prev;
      const nextItems = (prev.photoGroups?.[photoType] || []).filter((item) => {
        if (item.id !== itemId) return true;
        if (item.previewUrl && item.file) {
          URL.revokeObjectURL(item.previewUrl);
        }
        return false;
      });
      return {
        ...prev,
        photoGroups: {
          ...prev.photoGroups,
          [photoType]: nextItems,
        },
      };
    });
  }, []);

  const uploadDetailPhotos = useCallback(async (draftValue) => {
    const nextGroups = {};

    for (const photoType of PHOTO_TYPE_OPTIONS.map((item) => item.key)) {
      const items = Array.isArray(draftValue?.photoGroups?.[photoType]) ? draftValue.photoGroups[photoType] : [];
      const uploadedItems = [];

      for (const item of items) {
        if (item.persisted || !item.file) {
          uploadedItems.push(item);
          continue;
        }

        const encoded = await fileToBase64(item.file);
        const result = await postSheetAction("uploadPhotos", {
          payload: {
            itemKey: `${draftValue.key}||${photoType}`,
            productName: draftValue.productName,
            photos: [encoded],
          },
        }).catch(() => null);
        const uploaded = result?.data?.photos?.[0] || null;

        if (uploaded?.fileId) {
          uploadedItems.push({
            ...item,
            id: `${photoType}-${uploaded.fileId}`,
            fileId: uploaded.fileId,
            driveUrl: uploaded.driveUrl || uploaded.viewUrl || uploaded.previewUrl,
            previewUrl: uploaded.previewUrl || uploaded.viewUrl || uploaded.driveUrl,
            persisted: true,
          });
          continue;
        }

        uploadedItems.push(item);
      }

      nextGroups[photoType] = uploadedItems;
    }

    return nextGroups;
  }, [postSheetAction]);

  const buildPhotoTypeFileIdsMap = useCallback((photoGroups, scope) => {
    const map = {};
    PHOTO_TYPE_OPTIONS.filter((item) => item.scope === scope).forEach((item) => {
      map[item.key] = (photoGroups?.[item.key] || [])
        .map((photo) => String(photo.fileId || extractGoogleDriveId(photo.driveUrl || photo.previewUrl || "") || "").trim())
        .filter(Boolean);
    });
    return map;
  }, []);

  const validateRecordDetail = useCallback((draftValue) => {
    const min = parseBrixInput(draftValue?.brixMin);
    const max = parseBrixInput(draftValue?.brixMax);
    if (Number.isFinite(min) && Number.isFinite(max) && min > max) {
      return "理쒖? BRIX媛 理쒓퀬 BRIX蹂대떎 ?????놁뒿?덈떎.";
    }
    return "";
  }, []);

  const saveRecordDetail = useCallback(async () => {
    if (!recordDetailDraft) return;

    const validationError = validateRecordDetail(recordDetailDraft);
    if (validationError) {
      setError(validationError);
      return;
    }
    if (!currentJob?.job_key) {
      setError("?꾩옱 ?묒뾽 湲곗? CSV ?뺣낫媛 ?놁뒿?덈떎.");
      return;
    }

    setRecordDetailSaving(true);
    setError("");

    try {
      const uploadedPhotoGroups = await uploadDetailPhotos(recordDetailDraft);
      const inspectionPhotoTypeFileIdsMap = buildPhotoTypeFileIdsMap(uploadedPhotoGroups, "inspection");
      const movementPhotoTypeFileIdsMap = buildPhotoTypeFileIdsMap(uploadedPhotoGroups, "movement");
      const brixMin = parseBrixInput(recordDetailDraft.brixMin);
      const brixMax = parseBrixInput(recordDetailDraft.brixMax);
      const selectedCenterInfo =
        recordDetailDraft.product?.centers?.find((item) => item.center === recordDetailDraft.selectedCenter) || null;
      const selectedCenterQty = selectedCenterInfo?.totalQty || recordDetailDraft.product?.totalQty || 0;
      const existingMovements = Array.isArray(recordDetailDraft.existingRows?.movements)
        ? recordDetailDraft.existingRows.movements
        : [];
      const existingReturnRow = existingMovements.find(
        (row) =>
          String(row["泥섎━?좏삎"] || row["筌ｌ꼶??醫륁굨"] || "").trim() === "?뚯넚" &&
          String(row["?쇳꽣紐?] || row["??녠숲筌?"] || "").trim() === String(recordDetailDraft.selectedCenter || "").trim()
      );
      const existingExchangeRow = existingMovements.find(
        (row) =>
          String(row["泥섎━?좏삎"] || row["筌ｌ꼶??醫륁굨"] || "").trim() === "援먰솚" &&
          String(row["?쇳꽣紐?] || row["??녠숲筌?"] || "").trim() === String(recordDetailDraft.selectedCenter || "").trim()
      );

      const inspectionPayload = {
        type: "inspection",
        operationId: createOperationId(),
        key: `${recordDetailDraft.partnerName}||${recordDetailDraft.productCode}||inspection-detail`,
        ?묒뾽湲곗??쇰삉?봀SV?앸퀎媛? currentJob.job_key,
        ?곹뭹肄붾뱶: recordDetailDraft.productCode,
        ?곹뭹紐? recordDetailDraft.productName,
        ?묐젰?щ챸: recordDetailDraft.partnerName,
        ?꾩껜諛쒖＜?섎웾: recordDetailDraft.product?.totalQty || 0,
        諛쒖＜?섎웾: recordDetailDraft.product?.totalQty || 0,
        寃?덉닔?? parseQty(recordDetailDraft.inspectionQty),
        鍮꾧퀬: recordDetailDraft.memo,
        BRIX理쒖?: Number.isFinite(brixMin) ? Number(formatBrixValue(brixMin)) : "",
        BRIX理쒓퀬: Number.isFinite(brixMax) ? Number(formatBrixValue(brixMax)) : "",
        BRIX?됯퇏: recordDetailDraft.brixAvg ? Number(recordDetailDraft.brixAvg) : "",
        以묐웾硫붾え: recordDetailDraft.weightNote || "",
        expectedVersion: recordDetailDraft.existingRows?.inspection?.["踰꾩쟾"] || 0,
        expectedUpdatedAt: recordDetailDraft.existingRows?.inspection?.["?섏젙?쇱떆"] || "",
        replacePhotoFileIdsMode: true,
        photoTypeFileIdsMap: inspectionPhotoTypeFileIdsMap,
      };

      const rowsToSave = [
        inspectionPayload,
        {
          type: "movement",
          movementType: "RETURN",
          泥섎━?좏삎: "?뚯넚",
          replaceQtyMode: true,
          operationId: createOperationId(),
          key: `${recordDetailDraft.partnerName}||${recordDetailDraft.productCode}||RETURN||${recordDetailDraft.selectedCenter}`,
          ?묒뾽湲곗??쇰삉?봀SV?앸퀎媛? currentJob.job_key,
          ?곹뭹肄붾뱶: recordDetailDraft.productCode,
          ?곹뭹紐? recordDetailDraft.productName,
          ?묐젰?щ챸: recordDetailDraft.partnerName,
          ?쇳꽣紐? recordDetailDraft.selectedCenter,
          ?꾩껜諛쒖＜?섎웾: recordDetailDraft.product?.totalQty || 0,
          諛쒖＜?섎웾: selectedCenterQty,
          ?뚯넚?섎웾: parseQty(recordDetailDraft.returnQty),
          援먰솚?섎웾: 0,
          鍮꾧퀬: recordDetailDraft.memo,
          expectedVersion: existingReturnRow?.["踰꾩쟾"] || 0,
          expectedUpdatedAt: existingReturnRow?.["?섏젙?쇱떆"] || "",
          replacePhotoFileIdsMode: true,
          photoTypeFileIdsMap: { return: movementPhotoTypeFileIdsMap.return || [] },
        },
        {
          type: "movement",
          movementType: "EXCHANGE",
          泥섎━?좏삎: "援먰솚",
          replaceQtyMode: true,
          operationId: createOperationId(),
          key: `${recordDetailDraft.partnerName}||${recordDetailDraft.productCode}||EXCHANGE||${recordDetailDraft.selectedCenter}`,
          ?묒뾽湲곗??쇰삉?봀SV?앸퀎媛? currentJob.job_key,
          ?곹뭹肄붾뱶: recordDetailDraft.productCode,
          ?곹뭹紐? recordDetailDraft.productName,
          ?묐젰?щ챸: recordDetailDraft.partnerName,
          ?쇳꽣紐? recordDetailDraft.selectedCenter,
          ?꾩껜諛쒖＜?섎웾: recordDetailDraft.product?.totalQty || 0,
          諛쒖＜?섎웾: selectedCenterQty,
          ?뚯넚?섎웾: 0,
          援먰솚?섎웾: parseQty(recordDetailDraft.exchangeQty),
          鍮꾧퀬: recordDetailDraft.memo,
          expectedVersion: existingExchangeRow?.["踰꾩쟾"] || 0,
          expectedUpdatedAt: existingExchangeRow?.["?섏젙?쇱떆"] || "",
          replacePhotoFileIdsMode: true,
          photoTypeFileIdsMap: { exchange: movementPhotoTypeFileIdsMap.exchange || [] },
        },
      ];

      const saveResult = await postSheetAction("saveBatch", { rows: rowsToSave });
      const conflicts = saveResult?.data?.conflicts || [];

      if (conflicts.length) {
        setError("?쒕쾭 理쒖떊媛믨낵 異⑸룎?덉뒿?덈떎. ?덈줈怨좎묠 ???ㅼ떆 ?뺤씤??二쇱꽭??");
        setItemStatusMap((prev) => ({ ...prev, [recordDetailDraft.key]: "conflict" }));
        return;
      }

      await postSheetAction("postSaveSync", {
        payload: {
          hasInspection: true,
          hasMovement: true,
        },
      });

      const savedInspectionRow = saveResult?.data?.inspectionRows?.find((row) => row && !row.__conflict) || null;
      const savedMovementRows = (saveResult?.data?.movementRows || []).filter((row) => row && !row.__conflict);

      if (savedInspectionRow) {
        setInspectionRows((prev) => {
          const next = Array.isArray(prev) ? [...prev] : [];
          const targetIndex = next.findIndex(
            (row) =>
              String(row["작업기준일또는CSV식별값"] || row.jobKey || "").trim() === String(savedInspectionRow["작업기준일또는CSV식별값"] || currentJob.job_key || "").trim() &&
              normalizeProductCode(row["상품코드"] || row.productCode || "") === normalizeProductCode(savedInspectionRow["상품코드"] || savedInspectionRow.productCode || "") &&
              String(row["협력사명"] || row.partnerName || "").trim() === String(savedInspectionRow["협력사명"] || savedInspectionRow.partnerName || "").trim()
          );
          if (targetIndex >= 0) next[targetIndex] = { ...next[targetIndex], ...savedInspectionRow };
          else next.unshift(savedInspectionRow);
          return next;
        });
      }

      if (savedMovementRows.length) {
        setHistoryRows((prev) => {
          let next = Array.isArray(prev) ? [...prev] : [];
          savedMovementRows.forEach((savedRow) => {
            const targetIndex = next.findIndex(
              (row) =>
                String(row["작업기준일또는CSV식별값"] || row.jobKey || "").trim() === String(savedRow["작업기준일또는CSV식별값"] || currentJob.job_key || "").trim() &&
                normalizeProductCode(row["상품코드"] || row.productCode || "") === normalizeProductCode(savedRow["상품코드"] || savedRow.productCode || "") &&
                String(row["협력사명"] || row.partnerName || "").trim() === String(savedRow["협력사명"] || savedRow.partnerName || "").trim() &&
                String(row["센터명"] || row.centerName || "").trim() === String(savedRow["센터명"] || savedRow.centerName || "").trim() &&
                String(row["처리유형"] || row.typeName || "").trim() === String(savedRow["처리유형"] || savedRow.typeName || "").trim()
            );
            if (targetIndex >= 0) next[targetIndex] = { ...next[targetIndex], ...savedRow };
            else next.unshift(savedRow);
          });
          return next;
        });
      }

      setRecordDetailDraft((prev) =>
        prev
          ? {
              ...prev,
              existingRows: {
                inspection: savedInspectionRow || prev.existingRows.inspection,
                movements: savedMovementRows.length
                  ? [
                      ...savedMovementRows,
                      ...(prev.existingRows.movements || []).filter((row) => {
                        return !savedMovementRows.some(
                          (savedRow) =>
                            String(savedRow["센터명"] || savedRow.centerName || "").trim() === String(row["센터명"] || row.centerName || "").trim() &&
                            String(savedRow["처리유형"] || savedRow.typeName || "").trim() === String(row["처리유형"] || row.typeName || "").trim()
                        );
                      }),
                    ]
                  : prev.existingRows.movements,
              },
              photoGroups: uploadedPhotoGroups,
            }
          : prev
      );

      setMessage("내역 상세 수정이 저장되었습니다.");
    } catch (err) {
      setError(err.message || "?댁뿭 ?곸꽭 ??μ뿉 ?ㅽ뙣?덉뒿?덈떎.");
    } finally {
      setRecordDetailSaving(false);
    }
  }, [
    buildPhotoTypeFileIdsMap,
    closeRecordDetail,
    currentJob?.job_key,
    loadHistoryRows,
    loadInspectionRows,
    postSheetAction,
    recordDetailDraft,
    uploadDetailPhotos,
    validateRecordDetail,
  ]);

